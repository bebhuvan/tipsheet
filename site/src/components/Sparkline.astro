---
// Pure-SVG sparkline. Zero JS. Renders ~30 close prices into a 120×32 line.
interface Props {
  points: Array<{ close: number }>;
  width?: number;
  height?: number;
  stroke?: string;
  ariaLabel?: string;
}
const { points = [], width = 140, height = 36, stroke, ariaLabel = '' } = Astro.props;
const pad = 2;
const closes = (points || []).map(p => p.close).filter(v => v != null && Number.isFinite(v));

let pathD = '';
let direction = 'flat';
let fillD = '';
if (closes.length >= 2) {
  const min = Math.min(...closes);
  const max = Math.max(...closes);
  const range = (max - min) || 1;
  const stepX = (width - pad * 2) / (closes.length - 1);
  const pts = closes.map((c, i) => {
    const x = pad + i * stepX;
    const y = height - pad - ((c - min) / range) * (height - pad * 2);
    return [x, y];
  });
  pathD = 'M ' + pts.map(([x, y]) => `${x.toFixed(1)} ${y.toFixed(1)}`).join(' L ');
  // baseline fill for area under the curve
  fillD = `${pathD} L ${pts[pts.length-1][0].toFixed(1)} ${(height - pad).toFixed(1)} L ${pts[0][0].toFixed(1)} ${(height - pad).toFixed(1)} Z`;
  direction = closes[closes.length - 1] >= closes[0] ? 'up' : 'down';
}

const strokeColor = stroke || (direction === 'up' ? 'var(--up)' : direction === 'down' ? 'var(--down)' : 'var(--text-muted)');
const fillColor   = direction === 'up' ? 'var(--up)' : direction === 'down' ? 'var(--down)' : 'var(--text-muted)';
---
{closes.length >= 2 ? (
  <svg class={`spark spark-${direction}`} width={width} height={height} viewBox={`0 0 ${width} ${height}`} aria-label={ariaLabel} role="img">
    <path d={fillD} fill={fillColor} fill-opacity="0.08" stroke="none" />
    <path d={pathD} fill="none" stroke={strokeColor} stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
) : (
  <span class="spark-empty" aria-hidden="true">—</span>
)}
