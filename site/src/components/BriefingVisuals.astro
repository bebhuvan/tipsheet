---
const { visuals } = Astro.props;

const filings = Array.isArray(visuals?.filings) ? visuals.filings : [];
const market = Array.isArray(visuals?.market) ? visuals.market : [];
const categories = Array.isArray(visuals?.categories) ? visuals.categories : [];
const sectors = Array.isArray(visuals?.sectors) ? visuals.sectors : [];
const scoreBands = Array.isArray(visuals?.scoreBands) ? visuals.scoreBands : [];

const totalFilings = categories.reduce((sum, row) => sum + Number(row.count || 0), 0) || filings.length;
const maxCategoryCount = Math.max(1, ...categories.map(row => Number(row.count || 0)));
const maxSectorCount = Math.max(1, ...sectors.map(row => Number(row.count || 0)));
const maxBandCount = Math.max(1, ...scoreBands.map(row => Number(row.count || 0)));
const theme = visuals?.type === 'open' ? 'open' : 'close';
const label = theme === 'open' ? 'The Open' : 'The Close';

function parsePayload(row) {
  try {
    const payload = row?.tijori_widget_json ? JSON.parse(row.tijori_widget_json) : null;
    return payload && typeof payload === 'object' ? payload : null;
  } catch {
    return null;
  }
}

function asNumber(value) {
  const n = Number(value);
  return Number.isFinite(n) ? n : null;
}

function fmtNumber(value, digits = 1) {
  const n = asNumber(value);
  if (n === null) return null;
  return n.toLocaleString('en-IN', {
    maximumFractionDigits: digits,
    minimumFractionDigits: 0,
  });
}

function fmtCr(value) {
  const n = asNumber(value);
  if (n === null) return null;
  return `₹${fmtNumber(n, n >= 100 ? 0 : 1)} cr`;
}

function fmtMarketCapText(text, fallback) {
  const s = String(text || '').trim();
  if (!s) return fmtCr(fallback);
  if (/cr|crore|lakh/i.test(s)) return s;
  return `${s} cr`;
}

function fmtPct(value, signed = false) {
  const n = asNumber(value);
  if (n === null) return null;
  const sign = signed && n > 0 ? '+' : '';
  return `${sign}${fmtNumber(n, Math.abs(n) >= 10 ? 1 : 2)}%`;
}

function fmtMultiple(value) {
  const n = asNumber(value);
  if (n === null) return null;
  return `${fmtNumber(n, n >= 10 ? 1 : 2)}x`;
}

function trendClass(value) {
  const n = asNumber(value);
  if (n === null) return 'flat';
  if (n > 0) return 'up';
  if (n < 0) return 'down';
  return 'flat';
}

function marketName(row) {
  const names = {
    '^NSEI': 'Nifty 50',
    '^BSESN': 'Sensex',
    '^NSEBANK': 'Bank Nifty',
    '^INDIAVIX': 'India VIX',
  };
  return names[row.symbol] || row.name || row.symbol;
}

function scoreTier(score) {
  const n = Number(score || 0);
  if (n >= 9) return 'Alert';
  if (n >= 7) return 'Lead';
  return 'Brief';
}

function scoreClass(score) {
  const n = Number(score || 0);
  if (n >= 9) return 'hot';
  if (n >= 7) return 'warm';
  return 'cool';
}

function metricByName(table, names) {
  const metrics = Array.isArray(table?.metrics) ? table.metrics : [];
  const normalized = names.map(name => String(name).toLowerCase());
  return metrics.find(metric => {
    const label = String(metric.metric_name || '').toLowerCase();
    const path = String(metric.metric_path || '').toLowerCase();
    return normalized.some(name => label === name || path.endsWith(name));
  }) || null;
}

function metricLatest(table, names) {
  const metric = metricByName(table, names);
  const values = Array.isArray(metric?.values) ? metric.values : [];
  const ordered = values
    .map(value => ({
      period: value.period,
      index: Number(value.period_index ?? 0),
      value: asNumber(value.value),
    }))
    .filter(value => value.value !== null)
    .sort((a, b) => a.index - b.index);
  if (!ordered.length) return null;
  const latest = ordered.at(-1);
  const previous = ordered.length > 1 ? ordered.at(-2) : null;
  const delta = previous && previous.value !== 0
    ? ((latest.value - previous.value) / Math.abs(previous.value)) * 100
    : null;
  return { ...latest, previous, delta };
}

function statementTables(payload) {
  const statements = payload?.statements || {};
  return {
    annual: statements.pl_c_d || statements.pl_s_d || null,
    annualBasis: statements.pl_c_d ? 'Consolidated annual' : statements.pl_s_d ? 'Standalone annual' : null,
    quarter: statements.qt_c || statements.qt_s || null,
    quarterBasis: statements.qt_c ? 'Consolidated quarter' : statements.qt_s ? 'Standalone quarter' : null,
    ratios: statements.fr_c || statements.fr_s || null,
    ratiosBasis: statements.fr_c ? 'Consolidated ratios' : statements.fr_s ? 'Standalone ratios' : null,
    growth: statements.growth || null,
  };
}

function sourceUrl(row, payload) {
  const slug = payload?.slug || row.tijori_slug;
  return slug ? `https://www.tijorifinance.com/company/${encodeURIComponent(slug)}/` : null;
}

function eventValue(row) {
  const value = String(row.the_number_value || row.major_order_size || '').trim();
  return value && value !== 'null' ? value : null;
}

function eventValueCr(row) {
  const raw = eventValue(row);
  if (!raw) return null;
  const text = String(raw).replace(/,/g, '').toLowerCase();
  const numberMatch = text.match(/(\d+(?:\.\d+)?)/);
  if (!numberMatch) return null;
  const n = Number(numberMatch[1]);
  if (!Number.isFinite(n)) return null;
  if (text.includes('lakh')) return n / 100;
  if (text.includes('crore') || text.includes(' cr')) return n;
  if (text.includes('billion') || text.includes(' bn')) return n * 100;
  if (text.includes('million') || text.includes(' mn')) return n / 10;
  return null;
}

function ratioPct(numerator, denominator) {
  const a = asNumber(numerator);
  const b = asNumber(denominator);
  if (a === null || b === null || b === 0) return null;
  return (a / Math.abs(b)) * 100;
}

function fmtRatioPct(value) {
  const n = asNumber(value);
  if (n === null) return null;
  if (Math.abs(n) >= 100) return `${fmtNumber(n, 0)}%`;
  if (Math.abs(n) >= 10) return `${fmtNumber(n, 1)}%`;
  return `${fmtNumber(n, 2)}%`;
}

function possessive(symbol) {
  const s = String(symbol || '').trim();
  return s.endsWith('S') ? `${s}'` : `${s}'s`;
}

function joinFragments(parts) {
  return parts.filter(Boolean).join('; ');
}

function compactNote(label, metric) {
  if (!metric) return null;
  const delta = fmtPct(metric.delta, true);
  return delta ? `${delta} vs previous ${label}` : metric.period || null;
}

function factsFor(row) {
  const payload = parsePayload(row);
  const tables = statementTables(payload);
  const sales = metricLatest(tables.annual, ['Net Sales']);
  const profit = metricLatest(tables.annual, ['Net Profit']);
  const qSales = metricLatest(tables.quarter, ['Net Sales']);
  const qProfit = metricLatest(tables.quarter, ['Net Profit']);
  const de = metricLatest(tables.ratios, ['Debt to Equity Ratio']);
  const current = metricLatest(tables.ratios, ['Current Ratio']);
  const salesCagr = metricLatest(tables.growth, ['Sales CAGR']);
  const context = { sales, profit, qSales, qProfit, de, current, salesCagr };

  if (payload) {
    const facts = [
      { label: 'Market cap', value: fmtMarketCapText(payload.market_cap_text, row.market_cap), note: row.sector },
      { label: 'P/E', value: payload.pe ? fmtMultiple(payload.pe) : fmtMultiple(row.pe), note: 'Tijori latest' },
      { label: 'Sales', value: fmtCr(sales?.value), note: compactNote('year', sales) },
      { label: 'Net profit', value: fmtCr(profit?.value), note: compactNote('year', profit) },
      { label: 'Quarter sales', value: fmtCr(qSales?.value), note: compactNote('quarter', qSales) },
      { label: 'Quarter profit', value: fmtCr(qProfit?.value), note: compactNote('quarter', qProfit) },
      { label: 'Debt/equity', value: fmtMultiple(de?.value), note: tables.ratiosBasis },
      { label: 'Current ratio', value: fmtMultiple(current?.value), note: tables.ratiosBasis },
      { label: 'Sales CAGR', value: fmtPct(salesCagr?.value, true), note: salesCagr?.period },
    ].filter(fact => fact.value);

    return {
      source: 'Tijori SDK',
      sourceUrl: sourceUrl(row, payload),
      basis: [tables.annualBasis, tables.quarterBasis].filter(Boolean).join(' / '),
      facts: facts.slice(0, 6),
      prose: insightFor(row, facts, true, context),
    };
  }

  const fallbackFacts = [
    { label: 'Market cap', value: fmtCr(row.market_cap), note: row.sector },
    { label: 'P/E', value: fmtMultiple(row.pe), note: 'Screener feed' },
    { label: 'ROE', value: fmtPct(row.roe), note: 'Return profile' },
    { label: 'Debt/equity', value: fmtMultiple(row.debt_to_equity), note: 'Balance sheet' },
    { label: 'Revenue growth', value: fmtPct(row.revenue_growth, true), note: 'Screener feed' },
    { label: 'PAT growth', value: fmtPct(row.pat_growth, true), note: 'Screener feed' },
  ].filter(fact => fact.value);

  return {
    source: 'Screener feed',
    sourceUrl: sourceUrl(row, null),
    basis: null,
    facts: fallbackFacts.slice(0, 5),
    prose: insightFor(row, fallbackFacts, false, context),
  };
}

function insightFor(row, facts, hasSdk, context = {}) {
  const factMap = new Map(facts.map(fact => [fact.label, fact]));
  const salesFact = factMap.get('Sales') || factMap.get('Revenue growth');
  const profitFact = factMap.get('Net profit') || factMap.get('PAT growth');
  const leverage = factMap.get('Debt/equity');
  const cap = factMap.get('Market cap');
  const number = eventValue(row);
  const eventCr = eventValueCr(row);
  const mcapPct = ratioPct(eventCr, row.market_cap);
  const salesPct = ratioPct(eventCr, context.sales?.value);
  const salesDelta = fmtPct(context.sales?.delta, true);
  const profitDelta = fmtPct(context.profit?.delta, true);
  const qSalesDelta = fmtPct(context.qSales?.delta, true);
  const qProfitDelta = fmtPct(context.qProfit?.delta, true);
  const revGrowth = fmtPct(row.revenue_growth, true);
  const patGrowth = fmtPct(row.pat_growth, true);
  const roe = fmtPct(row.roe);
  const pe = fmtMultiple(row.pe);
  const deValue = context.de?.value !== undefined ? fmtMultiple(context.de.value) : leverage?.value;
  const category = String(row.category || row.event_type || '').toLowerCase();
  const headline = String(row.headline || '').toLowerCase();

  if (hasSdk && number && context.sales) {
    const scale = joinFragments([
      salesPct ? `${number} is ${fmtRatioPct(salesPct)} of latest annual sales` : null,
      mcapPct ? `${fmtRatioPct(mcapPct)} of market cap` : null,
      salesDelta ? `annual sales ${salesDelta}` : null,
      profitDelta ? `net profit ${profitDelta}` : null,
      deValue ? `debt/equity ${deValue}` : null,
    ]);
    if (category.includes('order')) {
      return `${possessive(row.symbol)} order is not just big; ${scale}. The pressure point is whether backlog conversion lifts margins without stretching receivables.`;
    }
    return `${possessive(row.symbol)} disclosure has scale: ${scale}. The question is whether this changes the operating base or only adds a large one-off item.`;
  }
  if (hasSdk && context.sales && context.profit) {
    const frame = joinFragments([
      `${fmtCr(context.sales.value)} sales`,
      `${fmtCr(context.profit.value)} profit`,
      salesDelta ? `sales ${salesDelta}` : null,
      profitDelta ? `profit ${profitDelta}` : null,
      qSalesDelta ? `latest-quarter sales ${qSalesDelta}` : null,
      qProfitDelta ? `latest-quarter profit ${qProfitDelta}` : null,
    ]);
    return `${row.symbol} is not just a headline here; the operating frame is ${frame}. That is the baseline the filing has to move.`;
  }
  if (number && cap) {
    const scale = joinFragments([
      mcapPct ? `${number} is ${fmtRatioPct(mcapPct)} of market cap` : `${number} against ${cap.value} market cap`,
      revGrowth ? `revenue growth ${revGrowth}` : null,
      patGrowth ? `PAT growth ${patGrowth}` : null,
      pe ? `P/E ${pe}` : null,
      leverage?.value ? `debt/equity ${leverage.value}` : null,
    ]);
    if (category.includes('order')) {
      return `${possessive(row.symbol)} order has scale: ${scale}. The follow-through to revenue and cash collection matters more than the win announcement.`;
    }
    if (category.includes('m&a') || headline.includes('acquir') || headline.includes('swap')) {
      return `${possessive(row.symbol)} transaction has balance-sheet weight: ${scale}. Financing, approvals and integration now matter more than the deal headline.`;
    }
    if (headline.includes('fraud') || headline.includes('rights') || headline.includes('account')) {
      return `${possessive(row.symbol)} governance issue is material: ${scale}. This is about trust, recoverability and controls, not just disclosure hygiene.`;
    }
    return `${possessive(row.symbol)} filing needs scale discipline: ${scale}. That keeps the disclosure from floating free of the company's financial base.`;
  }
  if (salesFact && profitFact) {
    return `${row.symbol} enters the tape with ${salesFact.label.toLowerCase()} at ${salesFact.value} and ${profitFact.label.toLowerCase()} at ${profitFact.value}; useful context before assigning weight to the filing.`;
  }
  if (leverage) {
    return `${possessive(row.symbol)} balance-sheet marker is visible here: debt/equity at ${leverage.value}, a useful check on how much room the company has to absorb the event.`;
  }
  return `${row.symbol} is on the tape because the filing cleared Tipsheet's editorial threshold; the next step is checking the company page and source filing.`;
}

const signalRows = filings.slice(0, 6).map(row => ({
  ...row,
  analysis: factsFor(row),
}));
const hasData = totalFilings > 0 || market.length > 0;
---

{hasData && (
  <section class={`briefing-visuals ${theme}`} aria-label={`${label} data digest`}>
    <div class="bv-header">
      <div>
        <span class="eyebrow">Data digest</span>
        <h2>What the tape is saying</h2>
      </div>
      <p>
        {totalFilings} exchange filings passed through this briefing window. The map below separates market mood, filing pressure and company fundamentals before the prose take.
      </p>
    </div>

    {market.length > 0 && (
      <div class="market-strip" aria-label="Market snapshot">
        {market.map(item => (
          <div class="market-cell">
            <span class="market-name">{marketName(item)}</span>
            <strong>{fmtNumber(item.price, item.symbol === '^BSESN' ? 0 : 2)}</strong>
            <span class={`market-change ${trendClass(item.change_pct)}`}>
              {fmtPct(item.change_pct, true) || 'Flat'}
            </span>
          </div>
        ))}
      </div>
    )}

    <div class="bv-grid">
      <section class="bv-panel">
        <div class="panel-heading">
          <span class="eyebrow">Filing pressure</span>
          <strong>{totalFilings}</strong>
        </div>

        <div class="band-list" aria-label="Editorial score bands">
          {scoreBands.map(band => (
            <div class="band-row">
              <span>{band.name}</span>
              <div class="bar-track"><i style={`width: ${Math.max(6, (Number(band.count || 0) / maxBandCount) * 100)}%`}></i></div>
              <b>{band.count}</b>
            </div>
          ))}
        </div>

        <div class="category-list" aria-label="Category concentration">
          {categories.map(category => (
            <div class="category-row">
              <span>{category.name}</span>
              <i style={`width: ${Math.max(8, (Number(category.count || 0) / maxCategoryCount) * 100)}%`}></i>
              <em>{category.count} filings / avg {fmtNumber(category.avg_score, 1)}</em>
            </div>
          ))}
        </div>
      </section>

      <section class="bv-panel sector-panel">
        <div class="panel-heading">
          <span class="eyebrow">Sector heat</span>
          <strong>{sectors.length}</strong>
        </div>
        <div class="sector-wheel" aria-label="Sector concentration">
          {sectors.map(sector => (
            <div class="sector-ray" style={`--ray: ${Math.max(16, (Number(sector.count || 0) / maxSectorCount) * 100)}%`}>
              <span>{sector.name}</span>
              <b>{sector.count}</b>
            </div>
          ))}
        </div>
      </section>
    </div>

    {signalRows.length > 0 && (
      <section class="signals">
        <div class="signals-heading">
          <span class="eyebrow">Company signals</span>
          <h3>Filings with financial context</h3>
        </div>

        <div class="signal-list">
          {signalRows.map(row => (
            <article class={`signal-card ${scoreClass(row.score)}`}>
              <a href={row.canonical_url} class="signal-main">
                <span class="signal-meta">
                  <b>{scoreTier(row.score)}</b>
                  <i>{row.symbol}</i>
                  {row.category && <em>{row.category}</em>}
                </span>
                <h4>{row.headline || row.company}</h4>
                <p>{row.analysis.prose}</p>
              </a>

              <div class="fact-grid">
                {row.analysis.facts.map(fact => (
                  <div class={`fact ${trendClass(String(fact.value).startsWith('+') ? 1 : 0)}`}>
                    <span>{fact.label}</span>
                    <strong>{fact.value}</strong>
                    {fact.note && <em>{fact.note}</em>}
                  </div>
                ))}
              </div>

              <div class="signal-source">
                <span>{row.analysis.source}{row.analysis.basis ? ` / ${row.analysis.basis}` : ''}</span>
                {row.analysis.sourceUrl && <a href={row.analysis.sourceUrl}>Open on Tijori</a>}
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </section>
)}

<style>
  .briefing-visuals {
    --brief-accent: var(--brief-close);
    margin: 36px 0 52px;
    border-top: 2px solid var(--text);
    border-bottom: 1px solid var(--text);
    padding: 22px 0 28px;
  }
  .briefing-visuals.open { --brief-accent: var(--brief-open); }

  .bv-header {
    display: grid;
    grid-template-columns: minmax(220px, 0.85fr) minmax(280px, 1.15fr);
    gap: 32px;
    align-items: end;
    margin-bottom: 22px;
  }
  .eyebrow {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--brief-accent);
    font-weight: 500;
  }
  .bv-header h2,
  .signals-heading h3 {
    margin: 4px 0 0;
    font-family: var(--serif);
    font-weight: 500;
    font-size: 30px;
    line-height: 1.05;
    color: var(--text);
  }
  .bv-header p {
    margin: 0;
    max-width: 42ch;
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.48;
    color: var(--text-soft);
    font-style: italic;
  }

  .market-strip {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .market-cell {
    min-width: 0;
    padding: 14px 16px;
    border-right: 1px solid var(--hairline);
    font-family: var(--mono);
  }
  .market-cell:last-child { border-right: 0; }
  .market-name {
    display: block;
    margin-bottom: 8px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .market-cell strong {
    display: block;
    font-size: 18px;
    line-height: 1;
    font-weight: 500;
    color: var(--text);
    font-feature-settings: "tnum" 1;
  }
  .market-change {
    display: block;
    margin-top: 7px;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }
  .market-change.up,
  .fact.up strong { color: #176747; }
  .market-change.down { color: var(--accent); }

  .bv-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 28px;
    margin-top: 28px;
  }
  .bv-panel {
    min-width: 0;
    border-top: 1px solid var(--text);
    padding-top: 16px;
  }
  .panel-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: baseline;
    margin-bottom: 18px;
  }
  .panel-heading strong {
    font-family: var(--serif);
    font-size: 42px;
    line-height: 0.9;
    font-weight: 400;
    color: var(--text);
  }

  .band-list {
    display: grid;
    gap: 10px;
    margin-bottom: 22px;
  }
  .band-row {
    display: grid;
    grid-template-columns: 54px 1fr 24px;
    gap: 12px;
    align-items: center;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .band-row b {
    color: var(--text);
    font-weight: 500;
    text-align: right;
  }
  .bar-track {
    height: 2px;
    background: var(--hairline);
  }
  .bar-track i,
  .category-row i {
    display: block;
    height: 100%;
    background: var(--brief-accent);
  }

  .category-list {
    display: grid;
    gap: 14px;
    padding-top: 18px;
    border-top: 1px solid var(--hairline);
  }
  .category-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 12px;
    align-items: center;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
  }
  .category-row i {
    height: 5px;
    align-self: end;
    background: color-mix(in srgb, var(--brief-accent) 70%, var(--text));
  }
  .category-row em {
    grid-column: 2;
    margin-top: -7px;
    font-family: var(--serif);
    font-size: 13px;
    line-height: 1.3;
    text-transform: none;
    letter-spacing: 0;
    color: var(--text-muted);
  }

  .sector-wheel {
    display: grid;
    gap: 10px;
  }
  .sector-ray {
    display: grid;
    grid-template-columns: minmax(116px, 0.72fr) 1fr 24px;
    gap: 12px;
    align-items: center;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .sector-ray::before {
    content: '';
    grid-column: 2;
    height: 1px;
    width: var(--ray);
    background: var(--text);
  }
  .sector-ray span {
    grid-column: 1;
    overflow-wrap: anywhere;
  }
  .sector-ray b {
    grid-column: 3;
    color: var(--text);
    font-weight: 500;
    text-align: right;
  }

  .signals {
    margin-top: 34px;
    padding-top: 20px;
    border-top: 1px solid var(--text);
  }
  .signals-heading {
    margin-bottom: 8px;
    max-width: 36ch;
  }
  .signals-heading .eyebrow {
    margin-bottom: 16px;
  }
  .signals-heading h3 {
    font-size: 24px;
  }
  .signal-list {
    display: grid;
    border-top: 1px solid var(--border);
  }
  .signal-card {
    display: grid;
    grid-template-columns: minmax(280px, 0.92fr) minmax(340px, 1.08fr);
