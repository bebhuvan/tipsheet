---
// Renders one Regulation/Economy note (handles both circular + RBI shapes).
const { note } = Astro.props;
function mdBold(s) {
  return String(s || '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
const paras = (s) => String(s || '').split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
const isCircular = note.kind === 'circular';
function sourceClass(source) {
  return `src-${String(source || '').toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
}
---
<article class="reg-note">
  <header class="reg-head">
    <div class="kicker"><span class={`reg-src ${sourceClass(note.source)}`}>{note.source}</span> · {note.category_label}{note.severity ? ` · ${note.severity}` : ''}</div>
    <h1 class="reg-headline">{note.headline}</h1>
    {note.dek && <p class="reg-dek">{note.dek}</p>}
    <div class="reg-meta">
      {note.date_label && <span>{note.date_label}</span>}
      {isCircular && note.effective_date && <span>Effective {note.effective_date}</span>}
      {isCircular && note.who_is_affected && <span>Affects: {note.who_is_affected}</span>}
    </div>
  </header>

  {note.what_changed?.length > 0 && (
    <section class="reg-block">
      <h2>What changed</h2>
      <ul>{note.what_changed.map(x => <li>{x}</li>)}</ul>
    </section>
  )}

  {note.the_read && (
    <section class="reg-block reg-read">
      <h2>The read</h2>
      {paras(note.the_read).map(p => <p set:html={mdBold(p)} />)}
    </section>
  )}

  {note.key_numbers?.length > 0 && (
    <section class="reg-block">
      <h2>Key numbers</h2>
      <ul class="reg-nums">{note.key_numbers.map(x => <li>{x}</li>)}</ul>
    </section>
  )}

  {isCircular && note.tables?.length > 0 && (
    <section class="reg-block">
      <h2>Affected securities</h2>
      {note.tables.map(t => (
        <div class="reg-table-wrap"><table class="reg-table">
          {t.map((row, i) => (
            <tr>{row.map(cell => (i === 0 ? <th>{cell}</th> : <td>{cell}</td>))}</tr>
          ))}
        </table></div>
      ))}
    </section>
  )}

  {isCircular && note.key_entities?.length > 0 && (
    <div class="reg-entities">{note.key_entities.map(e => <span class="reg-tag">{e}</span>)}</div>
  )}

  {note.source_url && (
    <p class="reg-source">Primary source: <a href={note.source_url} target="_blank" rel="noopener">{isCircular ? 'official circular (PDF)' : 'rbi.org.in'}</a></p>
  )}
</article>

<style>
  .reg-note { max-width: 720px; margin: 0 auto; padding: 8px 24px 72px; }

  /* ── Headline cluster ──────────────────────────────────────── */
  .reg-head .kicker {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 16px;
  }
  .reg-src { font-weight: 600; color: var(--text); }
  .reg-src.src-sebi { color: var(--accent); }
  .reg-src.src-rbi { color: var(--brief-close); }
  .reg-src.src-nse,
  .reg-src.src-bse,
  .reg-src.src-india-data-hub { color: var(--up); }

  .reg-headline {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(32px, 4.6vw, 50px);
    line-height: 1.06;
    letter-spacing: -0.022em;
    font-variation-settings: "opsz" 48;
    margin: 0 0 18px;
    color: var(--text);
    text-wrap: balance;
  }
  .reg-dek {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(19px, 1.7vw, 23px);
    line-height: 1.42;
    color: var(--text-soft);
    margin: 0 0 22px;
    max-width: 40ch;
    text-wrap: pretty;
    font-variation-settings: "opsz" 24;
  }
  .reg-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline-strong);
    padding: 13px 0;
    margin-bottom: 38px;
  }

  /* ── Body sections ─────────────────────────────────────────── */
  .reg-block { margin: 34px 0; }
  .reg-block h2 {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin: 0 0 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--hairline);
  }
  .reg-block ul { margin: 0; padding-left: 20px; }
  .reg-block li {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-soft);
    margin: 9px 0;
  }
  .reg-read p {
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.68;
    color: var(--text-soft);
    margin: 0 0 18px;
  }
  .reg-read p:last-child { margin-bottom: 0; }
  .reg-read strong { font-weight: 600; color: var(--text); }

  .reg-nums { list-style: none; padding: 0; margin: 0; }
  .reg-nums li {
    font-family: var(--mono);
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-soft);
    font-feature-settings: "tnum" 1;
    padding: 10px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .reg-nums li:last-child { border-bottom: 0; }

  .reg-table-wrap { overflow-x: auto; }
  .reg-table { border-collapse: collapse; width: 100%; font-family: var(--mono); font-size: 13px; margin-bottom: 14px; }
  .reg-table th, .reg-table td { border: 1px solid var(--hairline); padding: 8px 11px; text-align: left; vertical-align: top; }
  .reg-table th {
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text);
    background: color-mix(in srgb, var(--bg), var(--text) 2%);
  }
  .reg-table td { color: var(--text-soft); font-feature-settings: "tnum" 1; }

  .reg-entities { display: flex; flex-wrap: wrap; gap: 8px; margin: 22px 0; }
  .reg-tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    padding: 5px 11px;
    border: 1px solid var(--hairline-strong);
    color: var(--text-muted);
  }
  .reg-source {
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-top: 36px;
    border-top: 1px solid var(--hairline);
    padding-top: 16px;
  }
  .reg-source a { color: var(--accent); text-decoration: none; }
  .reg-source a:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .reg-note { padding: 8px 18px 56px; }
    .reg-headline { font-size: clamp(28px, 8vw, 38px); }
    .reg-read p { font-size: 18px; }
  }
</style>
