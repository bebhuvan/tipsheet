---
import { BRAND_NAME, BRAND_TAGLINE } from '../lib/brand.mjs';

interface Props {
  weekday?: string;
  stamp?: string;
  activeNav?: string;
}
const today = new Date();
const weekdays = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
const monthsLong = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const monthsShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const {
  weekday = weekdays[today.getDay()],
  dateline = `${weekdays[today.getDay()]}, ${today.getDate()} ${monthsLong[today.getMonth()]} ${today.getFullYear()}`,
  timeIst = `${String(today.getHours()).padStart(2,'0')}:${String(today.getMinutes()).padStart(2,'0')} IST`,
  stamp = `${today.getDate()} ${monthsShort[today.getMonth()]} · ${String(today.getHours()).padStart(2,'0')}:${String(today.getMinutes()).padStart(2,'0')} IST`,
  activeNav = 'today',
} = Astro.props;

const navItems = [
  { id: 'briefings',   label: 'Briefings',   href: '/briefings/' },
  { id: 'filings',     label: 'Latest',      href: '/filings/' },
  { id: 'radar',       label: 'Radar',       href: '/radar/' },
  { id: 'concalls',    label: 'Concalls',    href: '/concalls/' },
  { id: 'markets',     label: 'Markets',     href: '/markets/' },
];
---
<header class="masthead">
  <div class="masthead-util">
    <a href="/search/" class="masthead-search" aria-label="Search">Search <span class="kbd-hint">⌘K</span></a>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle colour scheme">
      <span class="dot"></span><span id="themeLabel">Light</span>
    </button>
  </div>
  <div class="masthead-dateline">
    {dateline} · Last updated {timeIst}
  </div>
  <div class="wordmark-block">
    <a href="/" class="word">{BRAND_NAME}</a>
    <div class="tagline">{BRAND_TAGLINE}</div>
  </div>
</header>

<nav class="site-nav" aria-label="Sections">
  <ul>
    {navItems.map(n => (
      <li><a href={n.href} class:list={[n.id === activeNav && 'active']}>{n.label}</a></li>
    ))}
  </ul>
</nav>
