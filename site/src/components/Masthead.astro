---
import { BRAND_NAME, BRAND_TAGLINE, BRAND_TELEGRAM_URL } from '../lib/brand.mjs';
import { latestPublishedContentAt } from '../lib/queries.mjs';

interface Props {
  weekday?: string;
  dateline?: string;
  timeIst?: string;
  stamp?: string;
  activeNav?: string;
  capTier?: string;
}
const today = latestPublishedContentAt() || new Date();
const istParts = Object.fromEntries(
  new Intl.DateTimeFormat('en-GB', {
    timeZone: 'Asia/Kolkata',
    weekday: 'long',
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    hour: 'numeric',
    minute: '2-digit',
    hour12: true,
  }).formatToParts(today).map(part => [part.type, part.value])
);
const monthShort = new Intl.DateTimeFormat('en-GB', {
  timeZone: 'Asia/Kolkata',
  month: 'short',
}).format(today);
const time12 = `${istParts.hour}:${istParts.minute} ${istParts.dayPeriod.toUpperCase()}`;
const {
  weekday = istParts.weekday,
  dateline = `${istParts.weekday}, ${istParts.day} ${istParts.month} ${istParts.year}`,
  timeIst = `${time12} IST`,
  stamp = `${istParts.day} ${monthShort} · ${time12} IST`,
  activeNav = 'today',
  capTier = '',
} = Astro.props;

const navItems = [
  { id: 'briefings',   label: 'Briefings',   href: '/briefings/' },
  { id: 'filings',     label: 'Latest',      href: '/filings/' },
  { id: 'radar',       label: 'Radar',       href: '/radar/' },
  { id: 'alerts',      label: 'Alerts',      href: '/alerts/' },
  { id: 'orders',      label: 'Orders',      href: '/orders/' },
  { id: 'concalls',    label: 'Concalls',    href: '/concalls/' },
  { id: 'regulation',  label: 'Regulation',  href: '/regulation/' },
  { id: 'economy',     label: 'Economy',     href: '/economy/' },
  { id: 'markets',     label: 'Markets',     href: '/markets/' },
];
// Mirrors MARKET_CAP_TIERS in queries.mjs — kept inline so the masthead stays
// decoupled from the data layer. A persistent "browse by size" sort control.
const capTiers = [
  { slug: 'mega-cap',  label: 'Mega' },
  { slug: 'large-cap', label: 'Large' },
  { slug: 'mid-cap',   label: 'Mid' },
  { slug: 'small-cap', label: 'Small' },
  { slug: 'micro-cap', label: 'Micro' },
];
---
<header class="masthead">
  <div class="masthead-util">
    <a href="/search/" class="masthead-search" aria-label="Search">Search <span class="kbd-hint">⌘K</span></a>
    <a href={BRAND_TELEGRAM_URL} target="_blank" rel="noopener" class="masthead-tg" aria-label="Tipsheet on Telegram" title="Follow on Telegram">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71l-4.07-3.01-1.96 1.91c-.21.21-.4.39-.74.39z"/></svg>
      <span>Telegram</span>
    </a>
    <a href="/feed.xml" class="masthead-rss" aria-label="Tipsheet RSS feed" title="Subscribe via RSS">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36zM4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
      <span>RSS</span>
    </a>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle colour scheme">
      <span class="dot"></span><span id="themeLabel">Light</span>
    </button>
  </div>
  <div class="masthead-dateline">
    {dateline} · Last updated {timeIst}
  </div>
  <div class="wordmark-block">
    <a href="/" class="word">{BRAND_NAME}</a>
    <div class="tagline">{BRAND_TAGLINE}</div>
  </div>
</header>

<nav class="site-nav" aria-label="Sections">
  <ul>
    {navItems.map(n => (
      <li><a href={n.href} class:list={[n.id === activeNav && 'active']}>{n.label}</a></li>
    ))}
  </ul>
</nav>

<nav class="cap-nav" aria-label="Browse filings by market capitalisation">
  <span class="cap-nav-label">By size</span>
  <ul>
    {capTiers.map(t => (
      <li><a href={`/filings/market-cap/${t.slug}/`} class:list={[t.slug === capTier && 'active']}>{t.label}</a></li>
    ))}
  </ul>
</nav>
