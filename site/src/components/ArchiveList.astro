---
// Editorial archive list — shared by all /filings/* pages, sectors, companies.
// "An edited ledger": day separators, a quiet serif score that accents on high
// conviction, a serif headline that warms to accent on hover, a two-line dek
// for substance, and mono micro-meta. Built entirely from the site's tokens.
import { filingEyebrow } from '../lib/queries.mjs';

const { items = [], emptyText = 'No notes here yet.' } = Astro.props;

const MON = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const DOW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const pad = (n) => String(n).padStart(2, '0');
function parse(iso) { const d = new Date(String(iso).replace(' ', 'T')); return Number.isNaN(d.valueOf()) ? null : d; }
function dayKey(iso) { const d = parse(iso); return d ? `${d.getFullYear()}-${pad(d.getMonth())}-${pad(d.getDate())}` : String(iso); }
function dayLabel(iso) { const d = parse(iso); return d ? `${DOW[d.getUTCDay() === d.getDay() ? d.getDay() : d.getDay()]} · ${pad(d.getDate())} ${MON[d.getMonth()]}` : String(iso); }
function timeOf(iso) { const m = String(iso || '').match(/(\d{2}):(\d{2})/); if (!m) return ''; let h = +m[1]; const ap = h < 12 ? 'AM' : 'PM'; h = h % 12 || 12; return `${h}:${pad(+m[2])} ${ap}`; }

// Precompute day-break flags so template stays declarative.
let last = null;
const rows = items.map((f) => {
  const k = dayKey(f.created_on);
  const head = k !== last ? dayLabel(f.created_on) : null;
  last = k;
  return { f, head };
});
---
<div class="fi-list">
  {rows.length === 0 && <p class="fi-empty">{emptyText}</p>}
  {rows.map(({ f, head }) => (
    <>
      {head && <div class="fi-daybreak"><span>{head}</span></div>}
      <a href={f.canonical_url} class="fi-row">
        <div class="fi-score" data-hi={f.score >= 8 ? 'true' : 'false'}>{f.score}</div>
        <div class="fi-main">
          <div class="fi-eyebrow">{filingEyebrow(f, { category: true, sector: true, cap: false }) || f.symbol}</div>
          <h3 class="fi-headline">{f.headline}</h3>
          {f.dek && <p class="fi-dek">{f.dek}</p>}
        </div>
        <div class="fi-meta">
          <span class="fi-ticker">{f.symbol}</span>
          {f.market_cap_label && <span class="fi-cap">{f.market_cap_label}</span>}
          <span class="fi-time">{timeOf(f.created_on)}</span>
        </div>
      </a>
    </>
  ))}
</div>

<style>
  .fi-list { border-top: 1px solid var(--hairline-strong); }
  .fi-empty { font-family: var(--serif); font-style: italic; color: var(--text-muted); padding: 28px 0; }

  .fi-daybreak {
    display: flex; align-items: center; gap: 16px;
    padding: 32px 0 14px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.24em;
    text-transform: uppercase; color: var(--text-faint);
  }
  .fi-daybreak::after { content: ''; flex: 1; height: 1px; background: var(--hairline); }

  .fi-row {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    gap: 28px;
    align-items: start;
    padding: 22px 0 24px;
    border-bottom: 1px solid var(--hairline);
    position: relative;
    text-decoration: none;
    color: inherit;
    transition: background 200ms ease;
  }
  .fi-row::before {
    content: ''; position: absolute; left: -22px; top: -1px; bottom: -1px; width: 2px;
    background: var(--accent); transform: scaleY(0); transform-origin: top center;
    transition: transform 240ms cubic-bezier(.2,.7,.3,1);
  }
  .fi-row:hover { background: var(--bg-soft); }
  .fi-row:hover::before { transform: scaleY(1); }

  .fi-score {
    font-family: var(--serif); font-weight: 200; font-size: 30px; line-height: .92;
    letter-spacing: -0.02em; color: var(--text-faint); padding-top: 1px;
    font-feature-settings: 'lnum' 1, 'tnum' 1; font-variant-numeric: lining-nums tabular-nums;
    transition: color 160ms ease;
  }
  .fi-row:hover .fi-score { color: var(--text-muted); }
  .fi-score[data-hi="true"] { color: var(--accent); }

  .fi-eyebrow {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-muted); margin-bottom: 8px;
  }
  .fi-headline {
    font-family: var(--serif); font-weight: 420; font-size: 22px; line-height: 1.28;
    letter-spacing: -0.013em; margin: 0; color: var(--text); max-width: 64ch;
    transition: color 160ms ease;
  }
  .fi-row:hover .fi-headline { color: var(--accent); }
  .fi-dek {
    font-family: var(--serif); font-size: 15.5px; line-height: 1.5; color: var(--text-muted);
    margin: 7px 0 0; max-width: 62ch;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .fi-meta {
    display: flex; flex-direction: column; align-items: flex-end; gap: 5px;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.08em;
    text-align: right; padding-top: 4px; white-space: nowrap;
  }
  .fi-ticker { color: var(--text); font-weight: 600; letter-spacing: 0.1em; }
  .fi-cap { color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.13em; }
  .fi-time { color: var(--text-faint); }

  @media (max-width: 720px) {
    .fi-row { grid-template-columns: 38px 1fr; gap: 16px; padding: 18px 0 20px; }
    .fi-row::before { left: -12px; }
    .fi-score { font-size: 23px; }
    .fi-headline { font-size: 18.5px; }
    .fi-dek { font-size: 14.5px; -webkit-line-clamp: 2; }
    .fi-meta {
      grid-column: 2; flex-direction: row; flex-wrap: wrap; align-items: center;
      justify-content: flex-start; text-align: left; gap: 12px; margin-top: 10px; padding-top: 0;
    }
  }
</style>
