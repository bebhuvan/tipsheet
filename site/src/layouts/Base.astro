  <!-- Icon system: SVG favicon (theme-aware), 192/512 PNG for Android + PWA,
       180x180 for Apple touch, web manifest for installability. -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="alternate icon" href="/icon-192.png" type="image/png" sizes="192x192" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#b5341e" />

  <!-- Site-wide org schema: ensures every page carries the NewsMediaOrganization entity,
       which is the trust signal Google's Quality Rater Guidelines look for on YMYL finance. -->
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <script is:inline>
    (function () {
      try {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-theme', stored || (prefersDark ? 'dark' : 'light'));
      } catch (_) {}
    })();
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link">Skip to content</a>
  <div id="main-content">
    <slot />
  </div>
  <script is:inline>
    (function () {
      const btn = document.getElementById('themeToggle');
      if (!btn) return;
      const lbl = document.getElementById('themeLabel');
      const setLbl = (t) => { if (lbl) lbl.textContent = t === 'dark' ? 'Dark' : 'Light'; };
      setLbl(document.documentElement.getAttribute('data-theme'));
      btn.addEventListener('click', () => {
        const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('theme', next); } catch (_) {}
        setLbl(next);
      });
    })();
  </script>
  <script is:inline>
    // Global ⌘K / Ctrl+K shortcut → /search/. Skips when typing in an input.
    (function () {
      document.addEventListener('keydown', (e) => {
        const isMeta = e.metaKey || e.ctrlKey;
        if (!isMeta || (e.key !== 'k' && e.key !== 'K')) return;
        const t = e.target;
        const inField = t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable);
        // On /search/ let the input handle focus; otherwise navigate.
        if (location.pathname.replace(/\/$/, '') === '/search') return;
        if (inField) return;
        e.preventDefault();
        location.assign('/search/');
      });
    })();
  </script>
</body>
</html>
