---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { listRegulation } from '../lib/queries.mjs';

const items = listRegulation({ limit: 150 });
---
<Base
  title="Regulation — SEBI, NSE, BSE & RBI, decoded"
  description="Editorial notes on the orders, circulars and rule changes from SEBI, the exchanges and the RBI that actually matter — enforcement, surveillance, derivatives, corporate actions and banking regulation."
>
  <Masthead activeNav="regulation" />
  <main>
    <article class="archive-page">
      <header class="archive-header">
        <div class="kicker"><span>The Rulebook</span></div>
        <h1 class="page-title">Regulation.</h1>
        <p class="page-dek">What SEBI, the exchanges and the RBI actually did — orders, enforcement, rule changes — read for what it means, grounded in the source. {items.length} published.</p>
      </header>
      <div class="archive-list">
        {items.length === 0 && <p style="font-style: italic; color: var(--text-muted); padding: 24px 0;">No regulation notes yet.</p>}
        {items.map(n => (
          <a href={n.canonical_url} class="archive-row">
            <span class="archive-date">{n.date_label}</span>
            <span class="archive-score">{n.source}</span>
            <div class="archive-body">
              <div class="kicker">{n.category_label}{n.severity ? ` · ${n.severity}` : ''}</div>
              <h3>{n.headline}</h3>
              {n.dek && <p class="archive-dek">{n.dek}</p>}
            </div>
          </a>
        ))}
      </div>
    </article>
  </main>
  <SiteFooter />
</Base>
