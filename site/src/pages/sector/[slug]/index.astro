---
import Base from '../../../layouts/Base.astro';
import Masthead from '../../../components/Masthead.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import ArchiveList from '../../../components/ArchiveList.astro';
import { distinctSectorsWithFilings, sectorBySlug, sectorSlug, filingsForSector, companiesInSector } from '../../../lib/queries.mjs';

export async function getStaticPaths() {
  const sectors = distinctSectorsWithFilings();
  return sectors.map(s => ({ params: { slug: sectorSlug(s.sector) } }));
}

const { slug } = Astro.params;
const sector = sectorBySlug(slug);
if (!sector) return Astro.redirect('/404');

const items = filingsForSector(sector, 60);
const companies = companiesInSector(sector, 20);

function timeOf(iso) { const m = String(iso || '').match(/(\d{2}):(\d{2})/); if (!m) return ''; let h = +m[1]; const ap = h < 12 ? 'AM' : 'PM'; h = h % 12 || 12; return `${h}:${m[2]} ${ap} IST`; }
function dateOf(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${String(d.getDate()).padStart(2,'0')} ${months[d.getMonth()]}`;
}
function fmtCr(n) {
  if (n == null) return '—';
  if (n >= 100000) return `₹${(n/100000).toFixed(2)} lakh cr`;
  return `₹${Math.round(n).toLocaleString('en-IN')} cr`;
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'Sectors', item: new URL('/sectors/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: sector, item: new URL(`/sector/${slug}/`, Astro.site).toString() },
  ],
};

// ItemList of the anchor companies in the sector — an extractable map of "who's
// in <sector>" for both Search and LLM answers.
const companiesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${sector} companies tracked by Tipsheet`,
  numberOfItems: companies.length,
  itemListElement: companies.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: new URL(`/company/${String(c.symbol).toLowerCase()}/`, Astro.site).toString(),
    name: c.symbol,
  })),
};

const schemaOutput = [breadcrumbSchema, companiesSchema];
---
<Base
  title={`${sector} — sector activity`}
  description={`Notes from companies in the ${sector} sector. Editorial coverage of every consequential disclosure, with company-level fundamentals snapshot.`}
  schema={schemaOutput}
>
  <Masthead activeNav="filings" />

  <main>
    <article class="archive-page">
      <header class="archive-header">
        <div class="kicker"><a href="/filings/">Notes</a> <span class="sep">/</span> <span>Sector</span></div>
        <h1 class="page-title">{sector}</h1>
        <p class="page-dek">{items.length} recent {items.length === 1 ? 'note' : 'notes'} from companies in this sector. {companies.length} companies tracked.</p>
      </header>

      <section class="sector-companies">
        <div class="block-title">Anchor companies · by market cap</div>
        <div class="company-chips">
          {companies.slice(0, 16).map(c => (
            <a href={`/company/${String(c.symbol).toLowerCase()}/`} class="chip">
              <span class="chip-sym mono">{c.symbol}</span>
              <span class="chip-mcap mono">{fmtCr(c.market_cap)}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="sector-activity">
        <div class="block-title">Recent activity</div>
        <ArchiveList items={items} emptyText="No notes from this sector yet." />
      </section>
    </article>
  </main>

  <SiteFooter />
</Base>
