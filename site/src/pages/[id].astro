---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { listAllForStaticPaths, getFiling, priorFilingsForSymbol, recordIdFromSlug, sourceLinks, getFundamentals, getFundamentalContext, getTijoriWidget, tierFor, filingsCountForSymbol, tijoriCompanyUrl } from '../lib/queries.mjs';

export async function getStaticPaths() {
  const all = listAllForStaticPaths();
  return all.map(item => ({ params: { id: item.id } }));
}

const { id } = Astro.params;
const recordId = recordIdFromSlug(id);
const filing = recordId ? getFiling(recordId) : null;

if (!filing) {
  return Astro.redirect('/404');
}

const prior = priorFilingsForSymbol(filing.symbol, filing.record_id, 4);
const totalForSymbol = filingsCountForSymbol(filing.symbol);
const priorCount = Math.max(0, totalForSymbol - 1);
const sources = sourceLinks(filing);
const primarySourceUrls = [sources.bse_announcements, sources.nse_announcements].filter(Boolean);
const fund = getFundamentals(filing.symbol);
const fundContext = fund?.sector ? getFundamentalContext(filing.symbol, fund.sector) : null;
const tijoriWidgetRow = getTijoriWidget(filing.symbol);
const tijoriWidget = tijoriWidgetRow?.payload;
const tijoriUrl = tijoriCompanyUrl({ tijori_slug: tijoriWidget?.slug || fund?.tijori_slug });

function fmtCr(n) {
  if (n == null) return '—';
  if (n >= 100000) return `₹${(n/100000).toFixed(2)} lakh cr`;
  return `₹${Number(n).toLocaleString('en-IN')} cr`;
}
function fmtNum(n, d = 2) { return n == null ? '—' : Number(n).toFixed(d); }
function fmtPct(n) { return n == null ? '—' : `${Number(n).toFixed(2)}%`; }
function fmtSignedPct(n) {
  if (n == null) return '—';
  const v = Number(n);
  return `${v > 0 ? '+' : ''}${v.toFixed(2)}%`;
}
function fmtCrCompact(n) {
  if (n == null) return '—';
  const v = Number(n);
  if (Math.abs(v) >= 100000) return `₹${(v / 100000).toFixed(2)} lakh cr`;
  if (Math.abs(v) >= 1000) return `₹${Math.round(v).toLocaleString('en-IN')} cr`;
  return `₹${v.toLocaleString('en-IN', { maximumFractionDigits: 2 })} cr`;
}
function fmtVs(value, base, unit = '%') {
  if (value == null || base == null || Number(base) === 0) return null;
  const diff = Number(value) - Number(base);
  const label = diff >= 0 ? 'above' : 'below';
  return `${Math.abs(diff).toFixed(2)}${unit} ${label} sector median`;
}
function fmtVsPeer(value, base, unit = 'pp') {
  if (value == null || base == null || !Number.isFinite(Number(base))) return null;
  const diff = Number(value) - Number(base);
  const label = diff >= 0 ? 'above' : 'below';
  const suffix = unit === 'pp' ? 'pp' : unit;
  return `${Math.abs(diff).toFixed(2)} ${suffix} ${label} sector median`;
}
function fmtRelative(value, base, lowerWord = 'below', higherWord = 'above') {
  if (value == null || base == null || Number(base) === 0) return null;
  const diff = ((Number(value) / Number(base)) - 1) * 100;
  const label = diff >= 0 ? higherWord : lowerWord;
  return `${Math.abs(diff).toFixed(1)}% ${label} sector median`;
}
function isMetric(n) {
  return n != null && Number.isFinite(Number(n));
}
function sanePe(n) {
  const v = Number(n);
  return isMetric(n) && v > 0 && v < 500;
}
function saneYield(n) {
  const v = Number(n);
  return isMetric(n) && v >= 0 && v < 50;
}
function saneRoe(n) {
  const v = Number(n);
  return isMetric(n) && v > -100 && v < 100;
}
function saneDebt(n) {
  const v = Number(n);
  return isMetric(n) && v >= 0 && v < 20;
}
function saneGrowth(n) {
  const v = Number(n);
  return isMetric(n) && v > -100 && v < 500;
}
function pctOf(n, d) {
  if (!isMetric(n) || !isMetric(d) || Number(d) === 0) return null;
  return (Number(n) / Number(d)) * 100;
}
function cleanMarketCapText(text) {
  if (!text) return null;
  const s = String(text).trim();
  if (!s) return null;
  return /\b(cr|crore|lakh|bn|mn)\b/i.test(s) ? s : `${s} cr`;
}
function metricMatches(metric, names) {
  const hay = [
    metric?.metric_name,
    metric?.metric_code,
    metric?.metric_path,
  ].filter(Boolean).map(v => String(v).toLowerCase());
  return names.some(name => hay.includes(String(name).toLowerCase()));
}
function latestMetric(widget, statementKeys, names) {
  const statements = widget?.statements || {};
  for (const key of statementKeys) {
    const statement = statements[key];
    const metric = statement?.metrics?.find(m => metricMatches(m, names));
    const values = (metric?.values || []).filter(v => isMetric(v?.value));
    if (!values.length) continue;
    const latest = values[values.length - 1];
    const previous = values.length > 1 ? values[values.length - 2] : null;
    return {
      statement: key,
      name: metric.metric_name,
      value: Number(latest.value),
      period: latest.period,
      previous: previous ? Number(previous.value) : null,
      previousPeriod: previous?.period || null,
    };
  }
  return null;
}
function deltaPct(metric) {
  if (!metric || !isMetric(metric.value) || !isMetric(metric.previous) || Number(metric.previous) === 0) return null;
  return ((Number(metric.value) / Number(metric.previous)) - 1) * 100;
}
function dirDelta(metric, higherIsBetter = true) {
  const d = deltaPct(metric);
  if (d == null || Math.abs(d) < 0.05) return null;
  return (higherIsBetter ? d > 0 : d < 0) ? 'up' : 'down';
}
function fmtMetricCr(metric) {
  return metric ? fmtCrCompact(metric.value) : '—';
}
function fmtMetricPct(metric) {
  return metric ? fmtPct(metric.value) : '—';
}
function fmtMetricNum(metric, d = 2) {
  return metric ? fmtNum(metric.value, d) : '—';
}
function fmtDeltaLine(metric, label = 'vs prior period') {
  const d = deltaPct(metric);
  if (d == null) return metric?.period || null;
  return `${fmtSignedPct(d)} ${label}`;
}
function statementBasis(statementKey) {
  if (!statementKey) return null;
  return String(statementKey).includes('_c') || String(statementKey).endsWith('_c') ? 'Consolidated' : 'Standalone';
}

// Directional class helpers for financial metrics
function dirRoe(n)    { if (n == null) return null; if (n < 0) return 'down'; if (n >= 15) return 'up'; return null; }
function dirDe(n)     { if (n == null) return null; return Number(n) >= 1.5 ? 'down' : null; }
function dirGrowth(n) { if (n == null) return null; if (n < 0) return 'down'; if (n > 0) return 'up'; return null; }
function dirCash(n)   { if (n == null) return null; if (n < 0) return 'down'; if (n > 0) return 'up'; return null; }
function dirVs(value, base, higherIsBetter = true) {
  if (value == null || base == null) return null;
  const diff = Number(value) - Number(base);
  if (Math.abs(diff) < 0.01) return null;
  return (higherIsBetter ? diff > 0 : diff < 0) ? 'up' : 'down';
}
function fmtPrice(n) {
  if (n == null) return '—';
  if (Math.abs(n) >= 10000) return n.toLocaleString('en-IN', { maximumFractionDigits: 2 });
  if (Math.abs(n) < 10) return n.toFixed(3);
  return n.toFixed(2);
}
function scoreBand(s) {
  if (s >= 9) return 'score-hi';
  if (s >= 7) return 'score-mid';
  return 'score-low';
}
const toneLabels = ['Adverse', 'Strained', 'Uncertain', 'Routine', 'Constructive', 'Catalytic'];
function tonePosition(score) {
  if (score == null) return null;
  return Math.max(0, Math.min(100, Number(score)));
}

function timeOf(iso) {
  const m = String(iso || '').match(/(\d{2}:\d{2})/);
  return m ? `${m[1]} IST` : '';
}
function dateOf(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}
function daysAgo(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return '';
  const diff = Math.round((Date.now() - d.getTime()) / (1000 * 60 * 60 * 24));
  if (diff <= 0) return 'today';
  if (diff === 1) return '1d ago';
  return `${diff}d ago`;
}

const isoPublished = String(filing.created_on).replace(' ', 'T') + '+05:30';
const tonePct = tonePosition(filing.tone_score);
const showPe = sanePe(fund?.pe);
const showDividendYield = saneYield(fund?.dividend_yield);
const showRoe = saneRoe(fund?.roe);
const showDebt = saneDebt(fund?.debt_to_equity);
const showRevenueGrowth = saneGrowth(fund?.revenue_growth);
const showPatGrowth = saneGrowth(fund?.pat_growth);
const showQualityGroup = showRoe || showDebt || isMetric(fund?.free_cash_flow);
const showGrowthGroup = showRevenueGrowth || showPatGrowth;
const earningsYield = showPe ? 100 / Number(fund.pe) : null;
const fcfYield = pctOf(fund?.free_cash_flow, fund?.market_cap);
const valuationRead = showPe && fundContext?.median_pe
  ? `P/E is ${fmtRelative(fund.pe, fundContext.median_pe)}.`
  : null;
const qualityRead = showRoe && fundContext?.median_roe
  ? `ROE is ${fmtVsPeer(fund.roe, fundContext.median_roe)}.`
  : null;
const growthRead = showPatGrowth && fundContext?.median_pat_growth
  ? `PAT growth is ${fmtVsPeer(fund.pat_growth, fundContext.median_pat_growth)}.`
  : null;
const snapshotRead = [valuationRead, qualityRead, growthRead].filter(Boolean).slice(0, 3).join(' ');
const sdkMarketCap = cleanMarketCapText(tijoriWidget?.market_cap_text);
const sdkAnnualSales = latestMetric(tijoriWidget, ['pl_c_d', 'pl_s_d'], ['Net Sales']);
const sdkAnnualOpProfit = latestMetric(tijoriWidget, ['pl_c_d', 'pl_s_d'], ['operating_profit', 'Operating Profit']);
const sdkAnnualOpm = latestMetric(tijoriWidget, ['pl_c_d', 'pl_s_d'], ['op_profit_margin', 'OPM (%)']);
const sdkAnnualNetProfit = latestMetric(tijoriWidget, ['pl_c_d', 'pl_s_d'], ['Net Profit']);
const sdkQuarterSales = latestMetric(tijoriWidget, ['qt_c', 'qt_s'], ['Net Sales']);
const sdkQuarterOpProfit = latestMetric(tijoriWidget, ['qt_c', 'qt_s'], ['operating_profit', 'Operating Profit']);
const sdkQuarterNetProfit = latestMetric(tijoriWidget, ['qt_c', 'qt_s'], ['Net Profit']);
const sdkQuarterOpm = latestMetric(tijoriWidget, ['qt_c', 'qt_s'], ['operating_profit_margin', 'Operating Profit Margin']);
const sdkQuarterNpm = latestMetric(tijoriWidget, ['qt_c', 'qt_s'], ['net_profit_margin', 'Net Profit Margin']);
const sdkQuarterEps = latestMetric(tijoriWidget, ['qt_c', 'qt_s'], ['EPS']);
const sdkCurrentRatio = latestMetric(tijoriWidget, ['fr_c', 'fr_s'], ['Current Ratio']);
const sdkDebtEquity = latestMetric(tijoriWidget, ['fr_c', 'fr_s'], ['debt_equity_ratio', 'Debt to Equity Ratio']);
const sdkTotalDebt = latestMetric(tijoriWidget, ['fr_c', 'fr_s'], ['Total Debt (Crs)']);
const sdkEquity = latestMetric(tijoriWidget, ['fr_c', 'fr_s'], ['Shareholders Equity (Crs)']);
const sdkSalesCagr = latestMetric(tijoriWidget, ['growth'], ['Sales CAGR']);
const sdkEpsCagr = latestMetric(tijoriWidget, ['growth'], ['TTM EPS CAGR']);
const sdkPatMarginGrowth = latestMetric(tijoriWidget, ['growth'], ['PAT Margin (Abs Growth)']);
const sdkHasFinancials = !!(tijoriWidget && (
  sdkAnnualSales || sdkAnnualOpProfit || sdkAnnualNetProfit || sdkQuarterSales || sdkCurrentRatio || sdkSalesCagr
));
const sdkAnnualBasis = statementBasis(sdkAnnualSales?.statement || sdkAnnualNetProfit?.statement || sdkAnnualOpProfit?.statement);
const sdkQuarterBasis = statementBasis(sdkQuarterSales?.statement || sdkQuarterNetProfit?.statement || sdkQuarterOpProfit?.statement);
const sdkBalanceBasis = statementBasis(sdkCurrentRatio?.statement || sdkDebtEquity?.statement || sdkTotalDebt?.statement || sdkEquity?.statement);
const sdkRead = [
  sdkAnnualSales && `${sdkAnnualBasis || 'Annual'} sales were ${fmtMetricCr(sdkAnnualSales)} in ${sdkAnnualSales.period}${deltaPct(sdkAnnualSales) != null ? `, ${fmtDeltaLine(sdkAnnualSales, 'year on year')}` : ''}.`,
  sdkAnnualNetProfit && `${sdkAnnualBasis || 'Annual'} net profit was ${fmtMetricCr(sdkAnnualNetProfit)}${deltaPct(sdkAnnualNetProfit) != null ? `, ${fmtDeltaLine(sdkAnnualNetProfit, 'year on year')}` : ''}.`,
  sdkQuarterSales && `${sdkQuarterBasis || 'Latest'} quarter sales were ${fmtMetricCr(sdkQuarterSales)} in ${sdkQuarterSales.period}.`,
].filter(Boolean).slice(0, 3).join(' ');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: filing.headline,
  alternativeHeadline: filing.dek,
  datePublished: isoPublished,
  dateModified: isoPublished,
  // Per-article OG image. Google News uses this in the Top Stories carousel.
  image: [{
    '@type': 'ImageObject',
    url: new URL(`/og/${id}.png`, Astro.site).toString(),
    width: 1200,
    height: 630,
  }],
  author: [{ '@type': 'Organization', name: 'Tipsheet Editorial', url: Astro.site?.toString() + 'about' }],
  publisher: {
    '@type': 'Organization',
    name: 'Tipsheet',
    logo: { '@type': 'ImageObject', url: new URL('/logo.png', Astro.site).toString(), width: 600, height: 60 },
  },
  description: filing.dek,
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(filing.canonical_url, Astro.site).toString() },
  articleSection: filing.canonical_category,
  keywords: [filing.symbol, filing.company, filing.canonical_category, filing.sector].filter(Boolean).join(', '),
  about: {
    '@type': 'Corporation',
    name: filing.company,
    tickerSymbol: filing.symbol,
    identifier: filing.scripcode ? `BSE:${filing.scripcode}` : undefined,
    sameAs: [sources.bse_company, sources.nse_company, tijoriUrl].filter(Boolean),
  },
  // isBasedOn signals to Google and LLMs that this article derives from primary sources.
  // Once Tijori adds a direct filing URL, we replace these with the deep link.
  isBasedOn: primarySourceUrls.length ? primarySourceUrls : undefined,
  citation: primarySourceUrls.length ? primarySourceUrls.map(url => ({ '@type': 'CreativeWork', url })) : undefined,
  isAccessibleForFree: true,
};
---
<Base
  title={`${filing.headline}`}
  description={filing.dek}
  schema={schema}
  publishedTime={isoPublished}
  modifiedTime={isoPublished}
  ogImage={`/og/${id}.png`}
>
  <Masthead activeNav="filings" />

  <main>
    <article class="filing">
      <div class="kicker reveal">
        <span class:list={[filing.score >= 9 && 'tier-alert']}>{tierFor(filing.score)}</span>
        {filing.canonical_category && filing.canonical_category !== 'Other' && <>
          <span class="sep">/</span><span>{filing.canonical_category}</span>
        </>}
        {filing.sector && <>
          <span class="sep">/</span>
          <a href={`/sector/${(filing.sector || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')}/`} class="inline">{filing.sector}</a>
        </>}
      </div>

      <h1 class="headline reveal d1">{filing.headline}</h1>
      <p class="dek reveal d2">{filing.dek}</p>

      {priorCount > 0 && (
        <a href={`/company/${String(filing.symbol).toLowerCase()}/`} class="timeline-cta reveal d3">
          <span class="cta-mark">—</span>
          <span class="cta-text">
            <span class="cta-count">{priorCount}</span> earlier {priorCount === 1 ? 'story' : 'stories'} on {filing.company || filing.symbol}
          </span>
          <span class="cta-arrow">→</span>
        </a>
      )}

      <hr class="rule" />

      <div class="dateline reveal d3">
        <span><strong>{filing.symbol}</strong></span>
        {filing.scripcode && <span>BSE {filing.scripcode}</span>}
        <span>{dateOf(filing.created_on)} · {timeOf(filing.created_on)}</span>
        {(sources.bse_announcements || sources.nse_announcements) && (
          <span class="source-links">
            Verify on
            {sources.bse_announcements && <a href={sources.bse_announcements} target="_blank" rel="noopener" class="inline">BSE</a>}
            {sources.bse_announcements && sources.nse_announcements && <span class="src-sep"> · </span>}
            {sources.nse_announcements && <a href={sources.nse_announcements} target="_blank" rel="noopener" class="inline">NSE</a>}
          </span>
        )}
      </div>

      <div class="content">
        <aside class="gutter">
          <div class:list={['tier-block', scoreBand(filing.score)]}>
            <span class="tier-mark">{tierFor(filing.score)}</span>
            <div class="tier-meta">
              <span>Editorial tier</span>
            </div>
          </div>

          {fund && (
            <div class="fund-block">
              <h3>At a glance · <a href={`/company/${String(filing.symbol).toLowerCase()}/`} class="inline gutter-link">all notes on {filing.symbol}</a></h3>
              <dl class="facts">
                {fund.sector && <><dt>Sector</dt><dd>{fund.sector}</dd></>}
                {fund.market_cap != null && <><dt>Market cap</dt><dd>{fmtCr(fund.market_cap)}</dd></>}
                {showPe && <><dt>P/E</dt><dd>{fmtNum(fund.pe)}×</dd></>}
                {showRoe && <><dt>ROE</dt><dd>{fmtPct(fund.roe)}</dd></>}
                {showDebt && <><dt>Debt / equity</dt><dd>{fmtNum(fund.debt_to_equity)}</dd></>}
                {showDividendYield && <><dt>Div yield</dt><dd>{fmtPct(fund.dividend_yield)}</dd></>}
                {(fund.low_52w != null || fund.high_52w != null) && <>
                  <dt>52-week range</dt>
                  <dd>{fmtNum(fund.low_52w)} — {fmtNum(fund.high_52w)}</dd>
                </>}
              </dl>
              {tijoriUrl && <a href={tijoriUrl} target="_blank" rel="noopener" class="inline gutter-link">Research {filing.symbol} on Tijori Finance</a>}
            </div>
          )}

          {prior.length > 0 && (
            <>
              <h3>Story so far</h3>
              <ol class="timeline">
                <li class="current">
                  {filing.canonical_category || filing.event_type}
                  <time>Today · {timeOf(filing.created_on)}</time>
                </li>
                {prior.map(p => (
                  <li>
                    <a href={p.canonical_url} class="headline-link timeline-headline">{p.headline}</a>
                    <time>{daysAgo(p.created_on)}</time>
                  </li>
                ))}
              </ol>
            </>
          )}
        </aside>

        <div class="body">
          {filing.the_number?.value && (
            <div class="the-number">
              <span class="v">{filing.the_number.value}</span>
              <span class="l">{filing.the_number.label}</span>
            </div>
          )}

          {filing.editorial_tone && tonePct != null && (
            <aside class="tone-read" aria-label="Editorial read">
              <div class="tone-head">
                <span>Editorial read</span>
                <strong>{filing.editorial_tone}</strong>
              </div>
              <div class="tone-rail" style={`--tone-pos: ${tonePct}%`}>
                <span class="tone-track"></span>
                <span class="tone-marker" aria-hidden="true"></span>
              </div>
              <div class="tone-scale" aria-hidden="true">
                {toneLabels.map(label => <span class:list={[label === filing.editorial_tone && 'active']}>{label}</span>)}
              </div>
              {filing.tone_reason && <p>{filing.tone_reason}</p>}
              {filing.tone_confidence && <span class="tone-confidence">Confidence: {filing.tone_confidence}</span>}
            </aside>
          )}

          <h2>What's new</h2>
          <ul class="bullets">
            {filing.whats_new.map(b => <li>{b}</li>)}
          </ul>

          <h2>Why it matters</h2>
          <p>{filing.why_it_matters}</p>

          <h2>What we're watching</h2>
          <ul class="bullets">
            {filing.what_were_watching.map(b => <li>{b}</li>)}
          </ul>

          <h2>The full read</h2>
          {String(filing.the_full_read || '').split(/\n+/).filter(Boolean).map(para => <p>{para}</p>)}

          {filing.key_entities && filing.key_entities.length > 0 && (
            <div class="entities">
              Mentioned: {filing.key_entities.map((e, i) => <><span>{e}</span>{i < filing.key_entities.length - 1 ? ' · ' : ''}</>)}
            </div>
          )}

          <div class="end-mark" aria-hidden="true">§</div>

          {(sources.bse_announcements || sources.nse_announcements) && (
            <div class="primary-source">
              <span class="label">Primary source</span>
              {sources.bse_announcements && <a href={sources.bse_announcements} target="_blank" rel="noopener">BSE filings for {filing.symbol}</a>}
              {sources.nse_announcements && <a href={sources.nse_announcements} target="_blank" rel="noopener">NSE filings for {filing.symbol}</a>}
              {tijoriUrl && <a href={tijoriUrl} target="_blank" rel="noopener">Research {filing.symbol} on Tijori Finance</a>}
              <span class="note">Our reading is derived from the exchange filing. Verify on the exchange before acting.</span>
            </div>
          )}
        </div>
      </div>

      {sdkHasFinancials && (
        <section class="company-snapshot" aria-label={`Tijori SDK financials for ${filing.symbol}`}>
          <header class="cs-head">
            <div class="cs-id">
              <div class="cs-kicker">Tijori SDK snapshot</div>
              <h2 class="cs-name">{tijoriWidget?.name || filing.company || filing.symbol}</h2>
              {(tijoriWidget?.sector || fund?.sector) && <div class="cs-industry">{tijoriWidget?.sector || fund.sector}</div>}
            </div>
            <div class="cs-rank-block">
              {sdkMarketCap && <div class="cs-market-cap">{sdkMarketCap}</div>}
              {tijoriWidget?.pe != null && <div class="cs-rank">P/E {fmtNum(tijoriWidget.pe)}× · compact widget cache</div>}
            </div>
          </header>

          {tijoriUrl && (
            <a href={tijoriUrl} target="_blank" rel="noopener" class="cs-tijori-banner">
              <span>More financial data, filings and peer context on Tijori Finance</span>
              <strong>Open {filing.symbol} on Tijori</strong>
            </a>
          )}

          {sdkRead && (
            <div class="cs-read">
              <span>Financial read</span>
              <p>{sdkRead}</p>
            </div>
          )}

          <div class="cs-groups">
            <div class="cs-group">
              <h3 class="cs-group-title">{sdkAnnualBasis ? `${sdkAnnualBasis} annual` : 'Annual account'}</h3>
              <div class="cs-grid">
                {sdkAnnualSales && (
                  <div>
                    <dt>Net sales</dt>
                    <dd class:list={[dirDelta(sdkAnnualSales)]}>{fmtMetricCr(sdkAnnualSales)}</dd>
                    <p>{fmtDeltaLine(sdkAnnualSales, 'year on year')}</p>
                  </div>
                )}
                {sdkAnnualOpProfit && (
                  <div>
                    <dt>Operating profit</dt>
                    <dd class:list={[dirDelta(sdkAnnualOpProfit)]}>{fmtMetricCr(sdkAnnualOpProfit)}</dd>
                    <p>{fmtDeltaLine(sdkAnnualOpProfit, 'year on year')}</p>
                  </div>
                )}
                {sdkAnnualOpm && (
                  <div>
                    <dt>Operating margin</dt>
                    <dd class:list={[dirDelta(sdkAnnualOpm)]}>{fmtMetricPct(sdkAnnualOpm)}</dd>
                    <p>{sdkAnnualOpm.period}</p>
                  </div>
                )}
                {sdkAnnualNetProfit && (
                  <div>
                    <dt>Net profit</dt>
                    <dd class:list={[dirDelta(sdkAnnualNetProfit)]}>{fmtMetricCr(sdkAnnualNetProfit)}</dd>
                    <p>{fmtDeltaLine(sdkAnnualNetProfit, 'year on year')}</p>
                  </div>
                )}
                </div>
              </div>

            {(sdkQuarterSales || sdkQuarterOpProfit || sdkQuarterNetProfit || sdkQuarterOpm || sdkQuarterEps) && (
              <div class="cs-group">
                <h3 class="cs-group-title">{sdkQuarterBasis ? `${sdkQuarterBasis} quarter` : 'Latest quarter'}</h3>
                <div class="cs-grid">
                  {sdkQuarterSales && (
                    <div>
                      <dt>Sales</dt>
                      <dd class:list={[dirDelta(sdkQuarterSales)]}>{fmtMetricCr(sdkQuarterSales)}</dd>
                      <p>{fmtDeltaLine(sdkQuarterSales, 'vs prior quarter')}</p>
                    </div>
                  )}
                  {sdkQuarterOpProfit && (
                    <div>
                      <dt>Operating profit</dt>
                      <dd class:list={[dirDelta(sdkQuarterOpProfit)]}>{fmtMetricCr(sdkQuarterOpProfit)}</dd>
                      <p>{fmtDeltaLine(sdkQuarterOpProfit, 'vs prior quarter')}</p>
                    </div>
                  )}
                  {sdkQuarterNetProfit && (
                    <div>
                      <dt>Net profit</dt>
                      <dd class:list={[dirDelta(sdkQuarterNetProfit)]}>{fmtMetricCr(sdkQuarterNetProfit)}</dd>
                      <p>{fmtDeltaLine(sdkQuarterNetProfit, 'vs prior quarter')}</p>
                    </div>
                  )}
                  {sdkQuarterOpm && (
                    <div>
                      <dt>OP margin</dt>
                      <dd class:list={[dirDelta(sdkQuarterOpm)]}>{fmtMetricPct(sdkQuarterOpm)}</dd>
                      <p>{sdkQuarterOpm.period}</p>
                    </div>
                  )}
                  {sdkQuarterNpm && (
                    <div>
                      <dt>Net margin</dt>
                      <dd class:list={[dirDelta(sdkQuarterNpm)]}>{fmtMetricPct(sdkQuarterNpm)}</dd>
                      <p>{sdkQuarterNpm.period}</p>
                    </div>
                  )}
                  {sdkQuarterEps && (
                    <div>
                      <dt>EPS</dt>
                      <dd class:list={[dirDelta(sdkQuarterEps)]}>{fmtMetricNum(sdkQuarterEps, 2)}</dd>
                      <p>{fmtDeltaLine(sdkQuarterEps, 'vs prior quarter')}</p>
                    </div>
                  )}
                </div>
              </div>
            )}

            {(sdkCurrentRatio || sdkDebtEquity || sdkTotalDebt || sdkEquity) && (
              <div class="cs-group">
                <h3 class="cs-group-title">{sdkBalanceBasis ? `${sdkBalanceBasis} balance sheet` : 'Balance sheet'}</h3>
                <div class="cs-grid">
                  {sdkCurrentRatio && (
                    <div>
                      <dt>Current ratio</dt>
                      <dd>{fmtMetricNum(sdkCurrentRatio, 2)}×</dd>
                      <p>{sdkCurrentRatio.period}</p>
                    </div>
                  )}
                  {sdkDebtEquity && (
                    <div>
                      <dt>Debt / equity</dt>
                      <dd class:list={[dirDe(sdkDebtEquity.value)]}>{fmtMetricNum(sdkDebtEquity, 2)}×</dd>
                      <p>{fmtDeltaLine(sdkDebtEquity, 'vs prior year')}</p>
                    </div>
                  )}
                  {sdkTotalDebt && (
                    <div>
                      <dt>Total debt</dt>
                      <dd class:list={[dirDelta(sdkTotalDebt, false)]}>{fmtMetricCr(sdkTotalDebt)}</dd>
                      <p>{fmtDeltaLine(sdkTotalDebt, 'vs prior year')}</p>
                    </div>
                  )}
                  {sdkEquity && (
                    <div>
                      <dt>Shareholders' equity</dt>
                      <dd class:list={[dirDelta(sdkEquity)]}>{fmtMetricCr(sdkEquity)}</dd>
                      <p>{fmtDeltaLine(sdkEquity, 'vs prior year')}</p>
                    </div>
                  )}
                </div>
              </div>
            )}

            {(sdkSalesCagr || sdkEpsCagr || sdkPatMarginGrowth) && (
              <div class="cs-group">
                <h3 class="cs-group-title">Longer trend</h3>
                <div class="cs-grid">
                  {sdkSalesCagr && (
                    <div>
                      <dt>Sales CAGR</dt>
                      <dd class:list={[dirGrowth(sdkSalesCagr.value)]}>{fmtMetricPct(sdkSalesCagr)}</dd>
                      <p>{sdkSalesCagr.period} Tijori growth series</p>
                    </div>
                  )}
                  {sdkEpsCagr && (
                    <div>
                      <dt>TTM EPS CAGR</dt>
                      <dd class:list={[dirGrowth(sdkEpsCagr.value)]}>{fmtMetricPct(sdkEpsCagr)}</dd>
                      <p>{sdkEpsCagr.period} Tijori growth series</p>
                    </div>
                  )}
                  {sdkPatMarginGrowth && (
                    <div>
                      <dt>PAT margin growth</dt>
                      <dd class:list={[dirGrowth(sdkPatMarginGrowth.value)]}>{fmtMetricPct(sdkPatMarginGrowth)}</dd>
                      <p>{sdkPatMarginGrowth.period} absolute growth series</p>
                    </div>
                  )}
                </div>
              </div>
            )}
          </div>

          <footer class="cs-foot">
            <span class="cs-asof">Compact widget data via the Tijori SDK.</span>
            <span class="cs-note">A research aid, not investment advice. Verify source filings and current prices before acting.</span>
            {tijoriUrl && <a href={tijoriUrl} target="_blank" rel="noopener" class="cs-tijori">Full company research on Tijori Finance</a>}
          </footer>
        </section>
      )}
    </article>
  </main>

  <SiteFooter />
</Base>

