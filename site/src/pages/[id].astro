---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { listAllForStaticPaths, getFiling, priorFilingsForSymbol, recordIdFromSlug, sourceLinks, getFundamentals, getFundamentalContext, tierFor, filingsCountForSymbol, tijoriCompanyUrl } from '../lib/queries.mjs';
import { renderInline, renderProse } from '../lib/prose.mjs';
import '../styles/snapshot.css';

export async function getStaticPaths() {
  const all = listAllForStaticPaths();
  return all.map(item => ({ params: { id: item.id } }));
}

const { id } = Astro.params;
const recordId = recordIdFromSlug(id);
const filing = recordId ? getFiling(recordId) : null;

if (!filing) {
  return Astro.redirect('/404');
}

const prior = priorFilingsForSymbol(filing.symbol, filing.record_id, 4);
const totalForSymbol = filingsCountForSymbol(filing.symbol);
const priorCount = Math.max(0, totalForSymbol - 1);
const sources = sourceLinks(filing);
const primarySourceUrls = [sources.bse_announcements, sources.nse_announcements].filter(Boolean);
const fund = getFundamentals(filing.symbol);
const fundContext = fund?.sector ? getFundamentalContext(filing.symbol, fund.sector) : null;
const tijoriUrl = tijoriCompanyUrl({ tijori_slug: fund?.tijori_slug });

function fmtCr(n) {
  if (n == null) return '—';
  if (n >= 100000) return `₹${(n/100000).toFixed(2)} lakh cr`;
  return `₹${Number(n).toLocaleString('en-IN')} cr`;
}
function fmtNum(n, d = 2) { return n == null ? '—' : Number(n).toFixed(d); }
function fmtPct(n) { return n == null ? '—' : `${Number(n).toFixed(2)}%`; }
function fmtSignedPct(n) {
  if (n == null) return '—';
  const v = Number(n);
  return `${v > 0 ? '+' : ''}${v.toFixed(2)}%`;
}
function fmtCrCompact(n) {
  if (n == null) return '—';
  const v = Number(n);
  if (Math.abs(v) >= 100000) return `₹${(v / 100000).toFixed(2)} lakh cr`;
  if (Math.abs(v) >= 1000) return `₹${Math.round(v).toLocaleString('en-IN')} cr`;
  return `₹${v.toLocaleString('en-IN', { maximumFractionDigits: 2 })} cr`;
}
function fmtVs(value, base, unit = '%') {
  if (value == null || base == null || Number(base) === 0) return null;
  const diff = Number(value) - Number(base);
  const label = diff >= 0 ? 'above' : 'below';
  return `${Math.abs(diff).toFixed(2)}${unit} ${label} sector median`;
}
function fmtVsPeer(value, base, unit = 'pp') {
  if (value == null || base == null || !Number.isFinite(Number(base))) return null;
  const diff = Number(value) - Number(base);
  const label = diff >= 0 ? 'above' : 'below';
  const suffix = unit === 'pp' ? 'pp' : unit;
  return `${Math.abs(diff).toFixed(2)} ${suffix} ${label} sector median`;
}
function fmtRelative(value, base, lowerWord = 'below', higherWord = 'above') {
  if (value == null || base == null || Number(base) === 0) return null;
  const diff = ((Number(value) / Number(base)) - 1) * 100;
  const label = diff >= 0 ? higherWord : lowerWord;
  return `${Math.abs(diff).toFixed(1)}% ${label} sector median`;
}
function isMetric(n) {
  return n != null && Number.isFinite(Number(n));
}
function sanePe(n) {
  const v = Number(n);
  return isMetric(n) && v > 0 && v < 500;
}
function saneYield(n) {
  const v = Number(n);
  return isMetric(n) && v >= 0 && v < 50;
}
function saneRoe(n) {
  const v = Number(n);
  return isMetric(n) && v > -100 && v < 100;
}
function saneDebt(n) {
  const v = Number(n);
  return isMetric(n) && v >= 0 && v < 20;
}
function saneGrowth(n) {
  const v = Number(n);
  return isMetric(n) && v > -100 && v < 500;
}
function pctOf(n, d) {
  if (!isMetric(n) || !isMetric(d) || Number(d) === 0) return null;
  return (Number(n) / Number(d)) * 100;
}
function cleanMarketCapText(text) {
  if (!text) return null;
  const s = String(text).trim();
  if (!s) return null;
  return /\b(cr|crore|lakh|bn|mn)\b/i.test(s) ? s : `${s} cr`;
}
function metricMatches(metric, names) {
  const hay = [
    metric?.metric_name,
    metric?.metric_code,
    metric?.metric_path,
  ].filter(Boolean).map(v => String(v).toLowerCase());
  return names.some(name => hay.includes(String(name).toLowerCase()));
}
function scoreBand(s) {
  if (s >= 9) return 'score-hi';
  if (s >= 7) return 'score-mid';
  return 'score-low';
}
function dirVs(value, base, higherIsBetter = true) {
  if (value == null || base == null) return null;
  const diff = Number(value) - Number(base);
  if (Math.abs(diff) < 0.01) return null;
  return (higherIsBetter ? diff > 0 : diff < 0) ? 'up' : 'down';
}
function fmtPrice(n) {
  if (n == null) return '—';
  if (Math.abs(n) >= 10000) return n.toLocaleString('en-IN', { maximumFractionDigits: 2 });
  if (Math.abs(n) < 10) return n.toFixed(3);
  return n.toFixed(2);
}
const toneLabels = ['Adverse', 'Strained', 'Uncertain', 'Routine', 'Constructive', 'Catalytic'];
function tonePosition(score) {
  if (score == null) return null;
  return Math.max(0, Math.min(100, Number(score)));
}

function timeOf(iso) {
  const m = String(iso || '').match(/(\d{2}):(\d{2})/);
  if (!m) return '';
  let h = parseInt(m[1], 10);
  const ampm = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;
  return `${h}:${m[2]} ${ampm} IST`;
}
function dateOf(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}
function daysAgo(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return '';
  const diff = Math.round((Date.now() - d.getTime()) / (1000 * 60 * 60 * 24));
  if (diff <= 0) return 'today';
  if (diff === 1) return '1d ago';
  return `${diff}d ago`;
}

const isoPublished = String(filing.created_on).replace(' ', 'T') + '+05:30';
const tonePct = tonePosition(filing.tone_score);
const showPe = sanePe(fund?.pe);
const showDividendYield = saneYield(fund?.dividend_yield);
const showRoe = saneRoe(fund?.roe);
const showDebt = saneDebt(fund?.debt_to_equity);
const showRevenueGrowth = saneGrowth(fund?.revenue_growth);
const showPatGrowth = saneGrowth(fund?.pat_growth);
const showQualityGroup = showRoe || showDebt || isMetric(fund?.free_cash_flow);
const showGrowthGroup = showRevenueGrowth || showPatGrowth;
const earningsYield = showPe ? 100 / Number(fund.pe) : null;
const fcfYield = pctOf(fund?.free_cash_flow, fund?.market_cap);
const pegRatio = (showPe && showPatGrowth && Number(fund.pat_growth) > 0) ? Number(fund.pe) / Number(fund.pat_growth) : null;
const valuationRead = showPe && fundContext?.median_pe
  ? `P/E is ${fmtRelative(fund.pe, fundContext.median_pe)}.`
  : null;
const qualityRead = showRoe && fundContext?.median_roe
  ? `ROE is ${fmtVsPeer(fund.roe, fundContext.median_roe)}.`
  : null;
const growthRead = showPatGrowth && fundContext?.median_pat_growth
  ? `PAT growth is ${fmtVsPeer(fund.pat_growth, fundContext.median_pat_growth)}.`
  : null;
const snapshotRead = [valuationRead, qualityRead, growthRead].filter(Boolean).slice(0, 3).join(' ');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: filing.headline,
  alternativeHeadline: filing.dek,
  datePublished: isoPublished,
  dateModified: isoPublished,
  // Per-article OG image. Google News uses this in the Top Stories carousel.
  image: [{
    '@type': 'ImageObject',
    url: new URL(`/og/${id}.png`, Astro.site).toString(),
    width: 1200,
    height: 630,
  }],
  author: [{ '@type': 'Organization', name: 'Tipsheet Editorial', url: Astro.site?.toString() + 'about' }],
  publisher: {
    '@type': 'Organization',
    name: 'Tipsheet',
    logo: { '@type': 'ImageObject', url: new URL('/logo.png', Astro.site).toString(), width: 600, height: 60 },
  },
  description: filing.dek,
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(filing.canonical_url, Astro.site).toString() },
  articleSection: filing.canonical_category,
  keywords: [filing.symbol, filing.company, filing.canonical_category, filing.sector].filter(Boolean).join(', '),
  about: {
    '@type': 'Corporation',
    name: filing.company,
    tickerSymbol: filing.symbol,
    identifier: filing.scripcode ? `BSE:${filing.scripcode}` : undefined,
    sameAs: [sources.bse_company, sources.nse_company, tijoriUrl].filter(Boolean),
  },
  isBasedOn: primarySourceUrls.length ? primarySourceUrls : undefined,
  citation: primarySourceUrls.length ? primarySourceUrls.map(url => ({ '@type': 'CreativeWork', url })) : undefined,
  isAccessibleForFree: true,
};

const faqs = filing.faqs || [];
const faqSchema = faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(q => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: q.answer
    }
  }))
} : null;

const schemaOutput = faqSchema ? [schema, faqSchema] : schema;
---
<Base
  title={`${filing.headline}`}
  description={filing.dek}
  schema={schemaOutput}
  publishedTime={isoPublished}
  modifiedTime={isoPublished}
  ogImage={`/og/${id}.png`}
>
  <Masthead activeNav="filings" />

  <main>
    <article class="filing">
      <div class="kicker">
        <span class:list={[filing.score >= 9 && 'tier-alert']}>{tierFor(filing.score)}</span>
        {filing.canonical_category && filing.canonical_category !== 'Other' && <>
          <span class="sep">/</span><span>{filing.canonical_category}</span>
        </>}
        {filing.sector && <>
          <span class="sep">/</span>
          <a href={`/sector/${(filing.sector || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')}/`} class="inline">{filing.sector}</a>
        </>}
      </div>

      <h1 class="headline">{filing.headline}</h1>
      <p class="dek">{filing.dek}</p>

      {priorCount > 0 && (
        <a href={`/company/${String(filing.symbol).toLowerCase()}/`} class="timeline-cta">
          <span class="cta-mark">—</span>
          <span class="cta-text">
            <span class="cta-count">{priorCount}</span> earlier {priorCount === 1 ? 'story' : 'stories'} on {filing.company || filing.symbol}
          </span>
          <span class="cta-arrow">→</span>
        </a>
      )}

      <hr class="organic-divider" />

      <div class="dateline">
        <span><strong>{filing.symbol}</strong></span>
        {filing.scripcode && <span>BSE {filing.scripcode}</span>}
        <span>{dateOf(filing.created_on)} · {timeOf(filing.created_on)}</span>
        {(sources.bse_announcements || sources.nse_announcements) && (
          <span class="source-links">
            Verify on
            {sources.bse_announcements && <a href={sources.bse_announcements} target="_blank" rel="noopener" class="inline">BSE</a>}
            {sources.bse_announcements && sources.nse_announcements && <span class="src-sep"> · </span>}
            {sources.nse_announcements && <a href={sources.nse_announcements} target="_blank" rel="noopener" class="inline">NSE</a>}
          </span>
        )}
      </div>

      {fund && (
        <div class="stat-strip" aria-label="Key metrics for {filing.symbol}">
          {fund.market_cap != null && <div><span class="ss-k">Mkt cap</span><span class="ss-v">{fmtCr(fund.market_cap)}</span></div>}
          {showPe && <div><span class="ss-k">P/E</span><span class="ss-v">{fmtNum(fund.pe)}×</span></div>}
          {showRoe && <div><span class="ss-k">ROE</span><span class="ss-v">{fmtPct(fund.roe)}</span></div>}
          {showDebt && <div><span class="ss-k">Debt / eq.</span><span class="ss-v">{fmtNum(fund.debt_to_equity)}</span></div>}
          {showDividendYield && <div><span class="ss-k">Div yld</span><span class="ss-v">{fmtPct(fund.dividend_yield)}</span></div>}
        </div>
      )}

      <div class="content">
        <aside class="gutter glass-panel">
          <div class:list={['tier-block', scoreBand(filing.score)]}>
            <span class="tier-mark">{tierFor(filing.score)}</span>
            <div class="tier-meta">
              <span>Editorial tier</span>
            </div>
          </div>

          {fund && (
            <div class="fund-block">
              <h3>At a glance · <a href={`/company/${String(filing.symbol).toLowerCase()}/`} class="inline gutter-link">all notes on {filing.symbol}</a></h3>
              <dl class="facts">
                {fund.sector && <><dt>Sector</dt><dd>{fund.sector}</dd></>}
                {fund.market_cap != null && <><dt>Market cap</dt><dd>{fmtCr(fund.market_cap)}</dd></>}
                {showPe && <><dt>P/E</dt><dd>{fmtNum(fund.pe)}×</dd></>}
                {showRoe && <><dt>ROE</dt><dd>{fmtPct(fund.roe)}</dd></>}
                {fcfYield != null && <><dt>FCF yield</dt><dd>{fmtPct(fcfYield)}</dd></>}
                {showDebt && <><dt>Debt / equity</dt><dd>{fmtNum(fund.debt_to_equity)}</dd></>}
                {showDividendYield && <><dt>Div yield</dt><dd>{fmtPct(fund.dividend_yield)}</dd></>}
                {pegRatio != null && <><dt>PEG ratio</dt><dd>{fmtNum(pegRatio)}</dd></>}
                {(fund.low_52w != null || fund.high_52w != null) && <>
                  <dt>52-week range</dt>
                  <dd>{fmtNum(fund.low_52w)} — {fmtNum(fund.high_52w)}</dd>
                </>}
              </dl>
              {tijoriUrl && (
                <a href={tijoriUrl} target="_blank" rel="noopener" class="tijori-sidebar-btn">
                  <span class="tijori-title">Research {filing.symbol}</span>
                  <span class="tijori-meta">
                    <span>on Tijori Finance</span>
                    <span class="tijori-arrow">↗</span>
                  </span>
                </a>
              )}
            </div>
          )}

          {prior.length > 0 && (
            <>
              <h3>Story so far</h3>
              <ol class="timeline">
                <li class="current">
                  {filing.canonical_category || filing.event_type}
                  <time>Today · {timeOf(filing.created_on)}</time>
                </li>
                {prior.map(p => (
                  <li>
                    <a href={p.canonical_url} class="headline-link timeline-headline">{p.headline}</a>
                    <time>{daysAgo(p.created_on)}</time>
                  </li>
                ))}
              </ol>
            </>
          )}
        </aside>

        <div class="body">
          {filing.the_number?.value && (
            <div class="the-number">
              <span class="v">{filing.the_number.value}</span>
              <span class="l">{filing.the_number.label}</span>
            </div>
          )}

          {filing.editorial_tone && tonePct != null && (
            <aside class="tone-read" aria-label="Editorial read">
              <div class="tone-head">
                <span>Editorial read</span>
                <strong>{filing.editorial_tone}</strong>
              </div>
              <div class="tone-rail" style={`--tone-pos: ${tonePct}%`}>
                <span class="tone-track"></span>
                <span class="tone-marker" aria-hidden="true"></span>
              </div>
              <div class="tone-scale" aria-hidden="true">
                {toneLabels.map(label => <span class:list={[label === filing.editorial_tone && 'active']}>{label}</span>)}
              </div>
              {filing.tone_reason && <p>{filing.tone_reason}</p>}
              {filing.tone_confidence && <span class="tone-confidence">Confidence: {filing.tone_confidence}</span>}
            </aside>
          )}

          <h2>What's new with {filing.company || filing.symbol}</h2>
          <ul class="bullets">
            {filing.whats_new.map(b => <li set:html={renderInline(b)} />)}
          </ul>

          <h2>Why this matters for {filing.company || filing.symbol}</h2>
          <p set:html={renderInline(filing.why_it_matters)} />

          <h2>What we're watching</h2>
          <ul class="bullets">
            {filing.what_were_watching.map(b => <li set:html={renderInline(b)} />)}
          </ul>

          <h2>The full read</h2>
          <Fragment set:html={renderProse(filing.the_full_read)} />

          {faqs.length > 0 && (
            <div class="faq-block">
              <h2>Questions answered</h2>
              <dl>
                {faqs.map(faq => (
                  <div>
                    <dt>{faq.question}</dt>
                    <dd set:html={renderInline(faq.answer)} />
                  </div>
                ))}
              </dl>
            </div>
          )}

          {filing.key_entities && filing.key_entities.length > 0 && (
            <div class="entities">
              Mentioned: {filing.key_entities.map((e, i) => <><span>{e}</span>{i < filing.key_entities.length - 1 ? ' · ' : ''}</>)}
            </div>
          )}

          <div class="end-mark" aria-hidden="true">§</div>

          {(sources.bse_announcements || sources.nse_announcements) && (
            <div class="primary-source">
              <div class="ps-head">
                <span class="ps-label">Primary source</span>
                <span class="ps-links">
                  {sources.bse_announcements && <a href={sources.bse_announcements} target="_blank" rel="noopener" aria-label={`BSE filings for ${filing.symbol}`}>BSE</a>}
                  {sources.bse_announcements && sources.nse_announcements && <span class="ps-dot">·</span>}
                  {sources.nse_announcements && <a href={sources.nse_announcements} target="_blank" rel="noopener" aria-label={`NSE filings for ${filing.symbol}`}>NSE</a>}
                  {tijoriUrl && (sources.bse_announcements || sources.nse_announcements) && <span class="ps-dot">·</span>}
                  {tijoriUrl && <a href={tijoriUrl} target="_blank" rel="noopener" aria-label={`Research ${filing.symbol} on Tijori Finance`}>Tijori</a>}
                </span>
              </div>
              <p class="ps-note">Our reading of the company's own disclosure. Always confirm against the original source.</p>
            </div>
          )}
        </div>
      </div>

      <div id="snapshot-mount" data-symbol={filing.symbol} data-tijori-url={tijoriUrl || ''} aria-live="polite" hidden></div>
      <script>
        import { renderSnapshotHTML } from '../lib/snapshot.mjs';

        // Async, non-blocking: the article is already painted. We fetch the
        // pre-cached Tijori snapshot from the edge and render it in place. If
        // the symbol has no data yet (or the request fails), the box stays
        // hidden and the article is unaffected. All values are escaped in
        // renderSnapshotHTML, and the markup is first-party, so we parse it
        // with createContextualFragment (no script execution) rather than
        // assigning markup directly.
        const root = document.getElementById('snapshot-mount');
        if (root && root.dataset.symbol) {
          const symbol = root.dataset.symbol;
          const tijoriUrl = root.dataset.tijoriUrl || null;
          fetch('/api/widget/' + encodeURIComponent(symbol))
            .then((r) => (r.ok ? r.json() : null))
            .then((data) => {
              if (!data || !data.available || !data.widget) return;
              const markup = renderSnapshotHTML(data.widget, symbol, tijoriUrl);
              if (!markup) return;
              const frag = document.createRange().createContextualFragment(markup);
              root.replaceChildren(frag);
              root.hidden = false;
            })
            .catch(() => { /* widget data is optional — never block the article */ });
        }
      </script>
    </article>
  </main>

  <SiteFooter />
</Base>

<style>
  /* Compact key-stats strip — mobile only. On desktop the same data lives in
     the sidebar "At a glance"; here it's a slim scrollable row so the article
     starts immediately instead of behind a tall sidebar. */
  .stat-strip { display: none; }
  @media (max-width: 1100px) {
    .stat-strip {
      display: flex;
      gap: 28px;
      overflow-x: auto;
      margin: 2px 0 4px;
      padding: 14px 0;
      border-top: 1px solid var(--hairline-strong);
      border-bottom: 1px solid var(--hairline);
      scrollbar-width: none;
    }
    .stat-strip::-webkit-scrollbar { display: none; }
    .stat-strip > div { flex: 0 0 auto; }
    .ss-k {
      display: block;
      font-family: var(--mono);
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--text-muted);
      margin-bottom: 5px;
      white-space: nowrap;
    }
    .ss-v {
      display: block;
      font-family: var(--data);
      font-feature-settings: "tnum" 1, "lnum" 1;
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
      white-space: nowrap;
    }
  }

  .tone-read {
    margin: 34px 0 36px;
    padding: 18px 0 16px;
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline);
  }
  .tone-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 16px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .tone-head strong {
    font-family: var(--serif);
    font-size: 24px;
    line-height: 1;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--text);
    font-variation-settings: "opsz" 24;
  }
  .tone-rail {
    position: relative;
    height: 18px;
  }
  .tone-track {
    position: absolute;
    left: 0;
    right: 0;
    top: 8px;
    height: 1px;
    background:
      linear-gradient(90deg,
        color-mix(in srgb, var(--down) 55%, var(--hairline-strong)),
        var(--hairline-strong) 42%,
        color-mix(in srgb, var(--accent) 55%, var(--hairline-strong)));
  }
  .tone-track::before,
  .tone-track::after {
    content: '';
    position: absolute;
    top: -4px;
    width: 1px;
    height: 9px;
    background: var(--text-faint);
  }
  .tone-track::before { left: 0; }
  .tone-track::after { right: 0; }
  .tone-marker {
    position: absolute;
    left: var(--tone-pos);
    top: 3px;
    width: 10px;
    height: 10px;
    border: 1px solid var(--accent);
    border-radius: 50%;
    background: var(--bg);
    transform: translateX(-50%);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .tone-scale {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
    margin-top: 7px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
  .tone-scale span {
    min-width: 0;
