---
import Base from '../../layouts/Base.astro';
import Masthead from '../../components/Masthead.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { listBriefings } from '../../lib/queries.mjs';

const briefings = listBriefings(60);

function dateOf(ymd) {
  const d = new Date(ymd + 'T00:00:00');
  if (Number.isNaN(d.valueOf())) return ymd;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}
---
<Base
  title="Briefings — The Open and The Close"
  description="Twice-daily editorial briefings. The Open before market open at 09:15 IST. The Close after the bell at 15:30. What to watch, what just moved, why it matters."
>
  <Masthead />
  <main>
    <article class="prose-page">
      <header>
        <div class="kicker"><span>Briefings</span></div>
        <h1 class="page-title">Twice a day.</h1>
        <p class="page-dek">
          The Open runs before the market opens at 09:15 IST — three things to watch today, plus what landed on the wires overnight. The Close runs after the bell — what actually moved and why. Both end on a verdict.
        </p>
      </header>

      <hr class="rule" />

      <div class="briefing-list">
        {briefings.length === 0 && (
          <p class="briefing-empty">No briefings published yet — they will land here as the schedule activates.</p>
        )}
        {briefings.map(b => (
          <a href={b.canonical_url} class={`briefing-card ${b.type}`}>
            <div class="briefing-meta">
              <span class="briefing-label">{b.label}</span>
              <span class="briefing-date">{dateOf(b.date)}</span>
            </div>
            <h3 class="briefing-headline">{b.headline}</h3>
            {b.dek && <p class="briefing-dek">{b.dek}</p>}
            {b.the_take && <p class="briefing-take"><em>{b.the_take}</em></p>}
          </a>
        ))}
      </div>
    </article>
  </main>
  <SiteFooter />
</Base>

<style>
  .briefing-list { display: flex; flex-direction: column; margin-top: 28px; border-top: 1px solid var(--hairline-strong); }
  .briefing-card {
    display: block;
    padding: 28px 0 30px;
    border-bottom: 1px solid var(--hairline);
    border-left: 2px solid transparent;
    padding-left: 22px;
    text-decoration: none;
    color: inherit;
    transition: border-left-color 180ms ease, background 180ms ease;
  }
  .briefing-card:hover { background: var(--bg-soft); }
  .briefing-card.open  { border-left-color: var(--brief-open); }
  .briefing-card.close { border-left-color: var(--brief-close); }
  .briefing-meta {
    display: flex; gap: 16px; align-items: baseline;
    font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--text-muted); margin-bottom: 10px;
  }
  .briefing-label { color: var(--text); font-weight: 500; }
  .briefing-card.open  .briefing-label { color: var(--brief-open); }
  .briefing-card.close .briefing-label { color: var(--brief-close); }
  .briefing-headline {
    font-family: var(--serif); font-size: 24px; font-weight: 400;
    line-height: 1.2; letter-spacing: -0.012em; margin: 0 0 10px;
    max-width: 36ch; text-wrap: balance;
  }
  .briefing-dek {
    font-family: var(--serif); color: var(--text-soft); margin: 0 0 10px;
    font-size: 16px; line-height: 1.5; max-width: 60ch;
  }
  .briefing-take {
    font-family: var(--serif); font-style: italic; font-weight: 300;
    color: var(--text-muted); margin: 0; font-size: 14px; line-height: 1.5; max-width: 60ch;
  }
  .briefing-empty { font-family: var(--serif); font-style: italic; color: var(--text-muted); margin-top: 32px; }
</style>
