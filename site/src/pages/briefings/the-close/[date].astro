---
import Base from '../../../layouts/Base.astro';
import Masthead from '../../../components/Masthead.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import BriefingVisuals from '../../../components/BriefingVisuals.astro';
import { getBriefing, getBriefingVisuals, listAllBriefingsForStaticPaths } from '../../../lib/queries.mjs';

export async function getStaticPaths() {
  return listAllBriefingsForStaticPaths()
    .filter(b => b.type === 'close')
    .map(b => ({ params: { date: b.date } }));
}

const { date } = Astro.params;
const briefing = getBriefing('close', date);
if (!briefing) return Astro.redirect('/404');

function mentionedFilingRecordIds(sections) {
  const ids = [];
  for (const section of sections || []) {
    for (const item of section.items || []) {
      const match = String(item?.ref_url || '').match(/\/filings\/[^/]*-(\d+)\/?$/);
      if (match) ids.push(Number(match[1]));
    }
  }
  return [...new Set(ids)];
}

const visuals = getBriefingVisuals('close', date, mentionedFilingRecordIds(briefing.sections));

function dateOf(ymd) {
  const d = new Date(ymd + 'T00:00:00');
  if (Number.isNaN(d.valueOf())) return ymd;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}

const isoPublished = date + 'T10:30:00+05:30';  // ~16:00 IST in UTC
const schema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: briefing.headline,
  alternativeHeadline: briefing.dek,
  datePublished: isoPublished,
  dateModified:  isoPublished,
  author: [{ '@type': 'Organization', name: 'Tipsheet Editorial', '@id': new URL('/authors/filings-editorial/#person', Astro.site).toString() }],
  publisher: { '@id': new URL('/#org', Astro.site).toString() },
  description: briefing.dek,
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(briefing.canonical_url, Astro.site).toString() },
  articleSection: 'Briefings',
  isAccessibleForFree: true,
};
---
<Base
  title={`${briefing.headline} — The Close, ${dateOf(date)}`}
  description={briefing.dek}
  schema={schema}
  publishedTime={isoPublished}
  modifiedTime={isoPublished}
>
  <Masthead />
  <main>
    <article class="briefing-page">
      <div class="kicker reveal">
        <span class="brief-tag-close">The Close</span>
        <span class="sep">/</span>
        <span>{dateOf(date)} · 16:00 IST</span>
      </div>

      <h1 class="headline reveal d1">{briefing.headline}</h1>
      <p class="dek reveal d2">{briefing.dek}</p>

      <hr class="rule" />

      {briefing.the_take && (
        <div class="take-block">
          <span class="take-label">The take</span>
          <p>{briefing.the_take}</p>
        </div>
      )}

      <BriefingVisuals visuals={visuals} />

      <div class="sections">
        {briefing.sections.map(section => (
          <section class="briefing-section">
            <h2>{section.label}</h2>
            {section.body && String(section.body).split(/\n\n+/).filter(Boolean).map(para => <p class="section-body">{para}</p>)}
            {(section.items || []).filter(i => i?.ref_url).length > 0 && (
              <div class="section-mentions">
                <span class="mentions-label">Mentioned in this section</span>
                <ul>
                  {(section.items || []).filter(i => i?.ref_url).map(item => (
                    <li>
                      <a href={item.ref_url}>
                        {item.ref_symbol && <span class="mention-ref">{item.ref_symbol}</span>}
                        <span class="mention-text">{item.text}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </section>
        ))}
      </div>

      <footer class="briefing-foot">
        <a href="/briefings/" class="inline">← All briefings</a>
        <span>The Open runs before market open at 09:15 IST</span>
      </footer>
    </article>
  </main>
  <SiteFooter />
</Base>

<style>
  .briefing-page { max-width: 980px; margin: 0 auto; padding: 0 var(--gutter); }
  .kicker, .headline, .dek, .rule, .take-block, .sections, .briefing-foot { max-width: 760px; }
  .take-block { margin: 24px 0; padding: 16px 20px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .take-label { font-family: var(--mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); display: block; margin-bottom: 6px; }
  .take-block p { margin: 0; font-family: var(--serif); font-size: 18px; font-style: italic; line-height: 1.45; }
  .sections { margin-top: 32px; }
  .briefing-section { margin-bottom: 48px; }
  .briefing-section h2 {
    font-family: var(--serif); font-size: 24px; font-weight: 500;
    margin: 0 0 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .section-body {
    font-family: var(--serif);
    color: var(--text);
    margin: 0 0 16px;
    font-size: 18px;
    line-height: 1.6;
  }
  .section-body:last-of-type { margin-bottom: 12px; }
  .section-mentions {
    margin-top: 22px;
    padding: 16px 0 0;
    border-top: 1px solid var(--hairline);
  }
  .mentions-label {
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    display: block;
    margin-bottom: 8px;
  }
  .section-mentions ul { list-style: none; padding: 0; margin: 0; }
  .section-mentions li { margin: 4px 0; }
  .section-mentions a {
    display: flex; align-items: baseline; gap: 10px; color: var(--text); text-decoration: none;
    font-size: 13px; padding: 4px 0;
  }
  .section-mentions a:hover .mention-text { text-decoration: underline; }
  .mention-ref {
    font-family: var(--mono); font-size: 10px;
    color: var(--text); font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    min-width: 80px; flex-shrink: 0;
  }
  .mention-text { color: var(--text-muted); }
  .briefing-foot {
    margin-top: 48px; padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between;
    font-size: 13px; color: var(--text-muted);
  }
</style>
