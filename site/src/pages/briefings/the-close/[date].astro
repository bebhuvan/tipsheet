---
import Base from '../../../layouts/Base.astro';
import Masthead from '../../../components/Masthead.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import BriefingBody from '../../../components/BriefingBody.astro';
import { getBriefing, getBriefingEvents, getBriefingMarketStrip, listAllBriefingsForStaticPaths } from '../../../lib/queries.mjs';

export async function getStaticPaths() {
  return listAllBriefingsForStaticPaths()
    .filter(b => b.type === 'close')
    .map(b => ({ params: { date: b.date } }));
}

const { date } = Astro.params;
const briefing = getBriefing('close', date);
if (!briefing) return Astro.redirect('/404');

const events = getBriefingEvents(briefing.events);
const market = getBriefingMarketStrip();

function dateOf(ymd) {
  const d = new Date(ymd + 'T00:00:00');
  if (Number.isNaN(d.valueOf())) return ymd;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}

const isoPublished = date + 'T16:00:00+05:30';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: briefing.headline,
  alternativeHeadline: briefing.dek,
  datePublished: isoPublished,
  dateModified:  isoPublished,
  author: [{ '@type': 'Organization', name: 'Tipsheet Editorial', '@id': new URL('/authors/filings-editorial/#person', Astro.site).toString() }],
  publisher: { '@id': new URL('/#org', Astro.site).toString() },
  description: briefing.dek,
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(briefing.canonical_url, Astro.site).toString() },
  articleSection: 'Briefings',
  isAccessibleForFree: true,
};
---
<Base
  title={`${briefing.headline} — The Close, ${dateOf(date)}`}
  description={briefing.dek}
  schema={schema}
  publishedTime={isoPublished}
  modifiedTime={isoPublished}
>
  <Masthead />
  <main>
    <article class="briefing-page">
      <div class="kicker">
        <span class="brief-tag-close">The Close</span>
        <span class="sep">/</span>
        <span>{dateOf(date)} · 4:00 PM IST</span>
      </div>

      <h1 class="headline">{briefing.headline}</h1>
      <p class="dek">{briefing.dek}</p>

      <BriefingBody
        theme="close"
        theTake={briefing.the_take}
        market={market}
        events={events}
        dayMap={briefing.day_map}
        concalls={briefing.concalls}
        mgmtFlags={briefing.mgmt_flags}
        calendar={briefing.calendar}
        eventsLabel="What moved today"
        calendarLabel="Tomorrow"
      />

      <footer class="briefing-foot">
        <a href="/briefings/" class="inline">← Older briefings</a>
        <span>The Open publishes at 8:00 AM IST</span>
      </footer>
    </article>
  </main>
  <SiteFooter />
</Base>

<style>
  .briefing-page { max-width: 760px; margin: 0 auto; padding: 72px 0 0; }
  .briefing-foot {
    margin-top: 56px; padding-top: 22px;
    border-top: 1.5px solid var(--text);
    display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap;
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.06em;
    text-transform: uppercase; color: var(--text-muted);
  }
  .briefing-foot a { color: var(--text-muted); text-decoration: none; }
  .briefing-foot a:hover { color: var(--accent); }
  @media (max-width: 700px) { .briefing-page { padding-top: 40px; } }
</style>
