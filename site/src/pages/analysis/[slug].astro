---
// Results synthesis — "the numbers vs the call". One page per (concall,
// Earnings filing) pair, generated by pipeline/synthesis_enricher.mjs from our
// own published notes. isBasedOn points at BOTH internal sources: provenance
// raters and LLM verifiers can actually follow.
import Base from '../../layouts/Base.astro';
import Masthead from '../../components/Masthead.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { listSyntheses, getSynthesisBySlug, filingUrlForRecordId, getFundamentals, getTijoriWidget, tijoriCompanyUrl, sourceLinks } from '../../lib/queries.mjs';
import { renderInline, renderProse } from '../../lib/prose.mjs';
import { renderSnapshotHTML } from '../../lib/snapshot.mjs';
import { BRAND_NAME, EDITORIAL_BYLINE, EDITORIAL_BYLINE_SLUG } from '../../lib/brand.mjs';
import '../../styles/snapshot.css';

const ORG_ID = (Astro.site?.toString() || '') + '#org';
const PERSON_ID = (Astro.site?.toString() || '') + `authors/${EDITORIAL_BYLINE_SLUG}/#person`;
const AUTHOR_URL = (Astro.site?.toString() || '') + `authors/${EDITORIAL_BYLINE_SLUG}/`;

export async function getStaticPaths() {
  return listSyntheses({ limit: 5000 }).map(s => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const piece = getSynthesisBySlug(slug);
if (!piece) return Astro.redirect('/404');

const fund = getFundamentals(piece.symbol);
const tijoriUrl = tijoriCompanyUrl(fund);
const widget = getTijoriWidget(piece.symbol);
const snapshotHTML = widget?.payload ? renderSnapshotHTML(widget.payload, piece.symbol, tijoriUrl) : '';
const filingUrl = filingUrlForRecordId(piece.filing_record_id);
const sources = sourceLinks({ symbol: piece.symbol, scripcode: fund?.scripcode });
const publishedIso = piece.generated_at ? new Date(piece.generated_at).toISOString() : null;

function dateLabel(ms) {
  if (!ms) return '';
  const d = new Date(ms);
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const ist = new Date(d.getTime() + 5.5 * 3600 * 1000);
  return `${ist.getUTCDate()} ${months[ist.getUTCMonth()]} ${ist.getUTCFullYear()}`;
}

const internalSources = [
  filingUrl && new URL(filingUrl, Astro.site).toString(),
  new URL(piece.concall_url, Astro.site).toString(),
].filter(Boolean);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: piece.headline,
  alternativeHeadline: piece.dek,
  datePublished: publishedIso,
  dateModified: publishedIso,
  author: [{ '@type': 'Organization', '@id': PERSON_ID, name: EDITORIAL_BYLINE, url: AUTHOR_URL }],
  editor: { '@type': 'Person', '@id': (Astro.site?.toString() || '') + 'about/#bhuvan', name: 'Bhuvan' },
  publisher: { '@type': 'NewsMediaOrganization', '@id': ORG_ID, name: BRAND_NAME },
  description: piece.dek,
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(piece.canonical_url, Astro.site).toString() },
  articleSection: 'Analysis',
  keywords: [piece.symbol, piece.company, 'results', 'earnings call'].filter(Boolean).join(', '),
  about: { '@type': 'Corporation', name: piece.company, tickerSymbol: piece.symbol },
  isBasedOn: internalSources,
  citation: internalSources.map(url => ({ '@type': 'CreativeWork', url })),
  isAccessibleForFree: true,
};

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.toString() },
    { '@type': 'ListItem', position: 2, name: 'Analysis', item: new URL('/analysis/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: piece.company, item: new URL(`/company/${String(piece.symbol).toLowerCase()}/`, Astro.site).toString() },
    { '@type': 'ListItem', position: 4, name: piece.headline, item: new URL(piece.canonical_url, Astro.site).toString() },
  ],
};
---
<Base
  title={piece.headline}
  description={piece.dek}
  schema={[schema, breadcrumb]}
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
>
  <Masthead activeNav="analysis" />

  <main>
    <article class="synthesis-page">
      <header class="syn-header">
        <div class="kicker mono">
          <a href="/analysis/">Analysis</a> <span class="sep">/</span>
          <a href={`/company/${String(piece.symbol).toLowerCase()}/`}>{piece.company}</a>
          <span class="sep">·</span> <span>The numbers vs the call</span>
        </div>
        <h1>{piece.headline}</h1>
        <p class="dek">{piece.dek}</p>
        <div class="byline mono">
          {EDITORIAL_BYLINE} · {dateLabel(piece.generated_at)} ·
          {filingUrl && <a href={filingUrl} class="inline">results note</a>}
          {filingUrl && <span> + </span>}
          <a href={piece.concall_url} class="inline">concall note</a>
        </div>
      </header>

      <div class="syn-body">
        <h2>The numbers</h2>
        <ul class="bullets">
          {piece.the_numbers.map(b => <li set:html={renderInline(b)} />)}
        </ul>

        <h2>Management's story</h2>
        <ul class="bullets">
          {piece.managements_story.map(b => <li set:html={renderInline(b)} />)}
        </ul>

        {piece.key_quote?.quote && (
          <blockquote class="key-quote">
            <p>“{piece.key_quote.quote}”</p>
            {piece.key_quote.attribution && <cite>— {piece.key_quote.attribution}</cite>}
          </blockquote>
        )}

        <h2>Where they diverge</h2>
        <div set:html={renderProse(piece.divergence)} />

        <h2>The full read</h2>
        <div class="full-read" set:html={renderProse(piece.the_full_read)} />

        <h2>What we're watching</h2>
        <ul class="bullets">
          {piece.what_were_watching.map(b => <li set:html={renderInline(b)} />)}
        </ul>

        <div class="primary-source">
          <span class="ps-label mono">Built from</span>
          {filingUrl && <a href={filingUrl}>our results note</a>}
          {filingUrl && <span> · </span>}
          <a href={piece.concall_url}>our concall note</a>
          {sources.bse_announcements && <span> · </span>}
          {sources.bse_announcements && <a href={sources.bse_announcements} target="_blank" rel="noopener">BSE filings</a>}
        </div>
      </div>

      {snapshotHTML && (
        <section class="company-snapshot-block" aria-label={`Financials for ${piece.company}`} set:html={snapshotHTML} />
      )}
    </article>
  </main>

  <SiteFooter />
</Base>

<style>
  .synthesis-page { max-width: 720px; margin: 0 auto; padding: 24px 20px 64px; }
  .syn-header .kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--text-muted); margin-bottom: 14px; }
  .syn-header .kicker .sep { margin: 0 6px; }
  .syn-header h1 { font-size: clamp(28px, 4.5vw, 40px); line-height: 1.15; margin: 0 0 12px; }
  .syn-header .dek { font-size: 19px; line-height: 1.45; color: var(--text-secondary, #444); margin: 0 0 14px; }
  .byline { font-size: 13px; color: var(--text-muted); padding-bottom: 18px; border-bottom: 1px solid var(--hairline, #ddd); }
  .syn-body h2 { font-size: 15px; text-transform: uppercase; letter-spacing: 0.1em; margin: 30px 0 10px; }
  .bullets { padding-left: 20px; } .bullets li { margin: 8px 0; line-height: 1.55; }
  .key-quote { margin: 26px 0; padding: 18px 22px; border-left: 3px solid currentColor; font-size: 18px; line-height: 1.5; }
  .key-quote cite { display: block; margin-top: 8px; font-size: 13px; font-style: normal; color: var(--text-muted); }
  .full-read :global(p) { line-height: 1.62; }
  .primary-source { margin-top: 34px; padding-top: 16px; border-top: 1px solid var(--hairline, #ddd); font-size: 14px; }
  .ps-label { text-transform: uppercase; letter-spacing: 0.1em; font-size: 11px; margin-right: 8px; color: var(--text-muted); }
  .company-snapshot-block { margin-top: 36px; }
</style>
