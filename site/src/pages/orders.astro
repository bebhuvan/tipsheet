---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { listFilings } from '../lib/queries.mjs';

const items = listFilings({ category: 'Order Wins', limit: 100 });
function timeOf(iso) { const m = String(iso || '').match(/(\d{2}):(\d{2})/); if (!m) return ''; let h = +m[1]; const ap = h < 12 ? 'AM' : 'PM'; h = h % 12 || 12; return `${h}:${m[2]} ${ap} IST`; }
function dateOf(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${String(d.getDate()).padStart(2,'0')} ${months[d.getMonth()]}`;
}
---
<Base
  title="Order Wins — major contract awards"
  description="Every material order win disclosed to the BSE and NSE, with editorial commentary on what each one means for the company."
>
  <Masthead activeNav="orders" />
  <main>
    <article class="archive-page">
      <header class="archive-header">
        <div class="kicker"><span>Order Wins</span></div>
        <h1 class="page-title">Order Wins.</h1>
        <p class="page-dek">Contract awards and order-book updates. {items.length} published. We weight by deal-size-to-market-cap, not headline number.</p>
      </header>
      <div class="archive-list">
        {items.length === 0 && <p style="font-style: italic; color: var(--text-muted); padding: 24px 0;">No order-win notes yet.</p>}
        {items.map(f => (
          <a href={f.canonical_url} class="archive-row">
            <span class="archive-date">{dateOf(f.created_on)} · {timeOf(f.created_on)}</span>
            <span class={`archive-score ${f.score >= 8 ? 'accent' : ''}`}>{f.score}</span>
            <div class="archive-body">
              <div class="kicker">{f.sector}</div>
              <h3>{f.headline}</h3>
            </div>
            <span class="archive-ticker">{f.symbol}</span>
          </a>
        ))}
      </div>
    </article>
  </main>
  <SiteFooter />
</Base>
