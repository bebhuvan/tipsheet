---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<Base
  title="Search"
  description="Search Tipsheet — companies, sectors, and every note we've published."
>
  <Masthead />
  <main>
    <article class="search-page">
      <header class="search-head">
        <div class="kicker"><span>Search</span></div>
        <h1 class="search-title">Find a filing, company, or sector.</h1>
        <p class="search-dek">
          Every note we've published. Every company we cover. Every sector.
          Type to filter. Open with <kbd>⌘K</kbd> from anywhere.
        </p>
        <form class="search-form" autocomplete="off" onsubmit="return false">
          <input
            id="searchInput"
            type="search"
            class="search-input"
            placeholder="Try a ticker, company, sector, or topic…"
            spellcheck="false"
            autofocus
          />
          <div class="search-stats" id="searchStats"></div>
        </form>
      </header>

      <section class="search-results" id="searchResults" aria-live="polite"></section>
    </article>
  </main>
  <SiteFooter />
</Base>

<script is:inline>
(function () {
  const input    = document.getElementById('searchInput');
  const results  = document.getElementById('searchResults');
  const stats    = document.getElementById('searchStats');
  if (!input || !results) return;

  let index = [];
  let loaded = false;

  const tierClass = (s) => s >= 9 ? 'score-hi' : s >= 7 ? 'score-mid' : 'score-low';
  const tierName  = (s) => s >= 9 ? 'Alert'    : s >= 7 ? 'Lead'      : 'Brief';
  const dateOf = (iso) => {
    const d = new Date(String(iso || '').replace(' ', 'T'));
    if (isNaN(d.valueOf())) return '';
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + String(d.getFullYear()).slice(-2);
  };

  // tiny DOM helper: creates an element with optional className and textContent
  function h(tag, cls, txt) {
    const el = document.createElement(tag);
    if (cls) el.className = cls;
    if (txt != null) el.textContent = txt;
    return el;
  }

  function load() {
    return fetch('/search-index.json').then(r => r.json()).then(j => { index = j; loaded = true; });
  }

  function rank(e, terms) {
    let firstHit = Infinity;
    for (const t of terms) {
      const i = e.q.indexOf(t);
      if (i === -1) return -1;
      if (i < firstHit) firstHit = i;
    }
    let r = 1000 - firstHit;
    if (e.sym && terms.includes(e.sym.toLowerCase())) r += 500;
    if (e.s === 'company') r += 50;
    if (e.s === 'sector')  r += 30;
    if (e.s === 'filing' && e.sc != null) r += (e.sc - 5) * 4;
    return r;
  }

  function buildCompanyRow(e) {
    const a = h('a', 'r-row r-company');
    a.href = e.u;
    a.appendChild(h('span', 'r-tk',   e.sym));
    a.appendChild(h('span', 'r-name', e.h));
    a.appendChild(h('span', 'r-meta', e.sec || '—'));
    a.appendChild(h('span', 'r-ct',   e.n + ' notes'));
    return a;
  }
  function buildSectorRow(e) {
    const a = h('a', 'r-row r-sector');
    a.href = e.u;
    a.appendChild(h('span', 'r-name', e.h));
    a.appendChild(h('span', 'r-ct',   e.n + ' notes'));
    return a;
  }
  function buildFilingRow(e) {
    const a = h('a', 'r-row r-filing');
    a.href = e.u;
    a.appendChild(h('span', 'r-tk', e.sym));
    a.appendChild(h('span', 'r-tier ' + tierClass(e.sc), tierName(e.sc)));
    const body = h('div', 'r-body');
    const kicker = [];
    if (e.cat && e.cat !== 'Other') kicker.push(e.cat);
    if (e.sec) kicker.push(e.sec);
    if (e.cap) kicker.push(e.cap);
    body.appendChild(h('div', 'r-kicker',   kicker.join(' · ')));
    body.appendChild(h('div', 'r-headline', e.h));
    a.appendChild(body);
    a.appendChild(h('span', 'r-time', dateOf(e.t)));
    return a;
  }

  function buildGroup(title, items, builder) {
    const wrap = h('div', 'rg');
    const heading = h('h3', 'rg-title');
    heading.appendChild(document.createTextNode(title + ' '));
    heading.appendChild(h('span', 'rg-ct', String(items.length)));
    wrap.appendChild(heading);
    const ol = h('ol', 'rg-list');
    for (const e of items) {
      const li = document.createElement('li');
      li.appendChild(builder(e));
      ol.appendChild(li);
    }
    wrap.appendChild(ol);
    return wrap;
  }

  function render(query) {
    // Clear previous results safely
    while (results.firstChild) results.removeChild(results.firstChild);

    if (!query) {
      stats.textContent = loaded ? (index.length.toLocaleString() + ' entries indexed') : 'Loading index…';
      return;
    }
    const terms = query.toLowerCase().split(/\s+/).filter(Boolean);
    const hits = [];
    for (const e of index) {
      const r = rank(e, terms);
      if (r > 0) hits.push({ e, r });
    }
    hits.sort((a, b) => b.r - a.r);
    const top = hits.slice(0, 50);
    stats.textContent = hits.length === 0
      ? 'No matches'
      : (hits.length.toLocaleString() + ' match' + (hits.length === 1 ? '' : 'es') + ' · showing top ' + top.length);

    const groups = { filing: [], company: [], sector: [] };
    for (const { e } of top) groups[e.s].push(e);

    if (groups.company.length) results.appendChild(buildGroup('Companies',    groups.company, buildCompanyRow));
    if (groups.sector.length)  results.appendChild(buildGroup('Sectors',      groups.sector,  buildSectorRow));
    if (groups.filing.length)  results.appendChild(buildGroup('Notes', groups.filing,  buildFilingRow));
  }

  let timer;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    const q = input.value.trim();
    if (!loaded) {
      load().then(() => render(q));
    } else {
      timer = setTimeout(() => render(q), 30);
    }
  });

  const params = new URLSearchParams(location.search);
  const initial = params.get('q') || '';
  if (initial) input.value = initial;
  load().then(() => render(input.value.trim()));

  input.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { input.value = ''; render(''); }
  });
})();
</script>

<style>
  .search-page { max-width: 880px; margin: 0 auto; padding: 96px 0 120px; }
  .search-head { margin-bottom: 56px; }
  .search-head .kicker {
    font-family: var(--mono); font-size: 12px; letter-spacing: 0.24em;
    text-transform: uppercase; color: var(--text-muted);
    margin-bottom: 28px;
  }
  .search-title {
    font-family: var(--serif); font-weight: 400;
    font-size: clamp(36px, 4.4vw, 56px);
    line-height: 1.04; letter-spacing: -0.022em;
    margin: 0 0 20px; max-width: 22ch;
    font-variation-settings: "opsz" 48;
    text-wrap: balance;
  }
  .search-dek {
    font-family: var(--serif); font-style: italic; font-weight: 300;
    font-size: clamp(17px, 1.4vw, 20px);
    line-height: 1.45; color: var(--text-soft);
    margin: 0 0 40px; max-width: 56ch;
    font-variation-settings: "opsz" 20;
  }
  .search-dek kbd {
    font-family: var(--mono); font-size: 12px;
    padding: 2px 6px; border: 1px solid var(--hairline-strong);
    border-bottom-width: 2px; color: var(--text);
    font-style: normal; letter-spacing: 0.06em;
  }
  .search-form {
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--hairline);
    padding: 18px 0 14px;
  }
  .search-input {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 8px 0;
    color: var(--text);
    font-family: var(--serif);
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.012em;
    outline: none;
  }
  .search-input::placeholder { color: var(--text-faint); font-style: italic; font-weight: 300; }
  .search-stats {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--text-muted); margin-top: 14px;
    font-feature-settings: "tnum" 1;
  }

  .search-results { display: flex; flex-direction: column; gap: 64px; }
  .rg-title {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--text); font-weight: 500;
    margin: 0 0 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--text);
    display: flex; align-items: baseline; justify-content: space-between;
  }
  .rg-title .rg-ct {
    font-size: 12px; letter-spacing: 0.18em;
    color: var(--text-muted); font-weight: 400;
  }
  .rg-list { list-style: none; margin: 0; padding: 0; }
  .rg-list li { border-bottom: 1px solid var(--hairline); }
  .rg-list li:last-child { border-bottom: 0; }
  .r-row {
    display: grid;
    gap: 24px;
    align-items: baseline;
    padding: 18px 0;
    color: inherit;
    text-decoration: none;
    transition: background 180ms ease;
  }
  .r-row:hover { background: var(--bg-soft); }
  .r-company { grid-template-columns: 110px 1.2fr 1fr 90px; }
  .r-sector  { grid-template-columns: 1fr 90px; }
  .r-filing  { grid-template-columns: 92px 90px 1fr 100px; }

  .r-tk {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.16em; color: var(--text); font-weight: 500;
  }
  .r-name { font-family: var(--serif); font-size: 18px; color: var(--text); line-height: 1.3; }
  .r-meta {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.08em; color: var(--text-muted);
  }
  .r-ct {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.14em; color: var(--text-muted);
    text-align: right; font-feature-settings: "tnum" 1;
  }
  .r-tier {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    font-weight: 500;
    text-align: center;
  }
  .r-tier.score-hi  { color: var(--accent); }
  .r-tier.score-mid { color: var(--text); }
  .r-tier.score-low { color: var(--text-muted); }
  .r-body { min-width: 0; }
  .r-kicker {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--text-muted); margin-bottom: 6px;
  }
  .r-headline {
    font-family: var(--serif); font-size: 17px;
    line-height: 1.3; color: var(--text);
    letter-spacing: -0.012em;
    font-variation-settings: "opsz" 18;
  }
  .r-time {
    font-family: var(--mono); font-size: 12px;
    letter-spacing: 0.14em; color: var(--text-muted);
    text-align: right; font-feature-settings: "tnum" 1;
  }

  @media (max-width: 700px) {
    .search-page { padding: 56px 0 72px; }
    .r-company { grid-template-columns: 80px 1fr 70px; }
    .r-company .r-meta { display: none; }
    .r-filing { grid-template-columns: 64px 32px 1fr; gap: 14px; }
    .r-filing .r-time { display: none; }
  }
</style>
