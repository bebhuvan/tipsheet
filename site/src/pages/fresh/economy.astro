---
import Base from '../../layouts/Base.astro';
import Masthead from '../../components/Masthead.astro';
import PolicyArchive from '../../components/PolicyArchive.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { listEconomy } from '../../lib/queries.mjs';

const items = listEconomy({ limit: 150 });
---
<Base
  title="Economy — India's macro data, read for the signal"
  description="RBI and official data — forex reserves, lending and deposit rates, trade, the RBI Bulletin — turned into short, sourced reads on what each print signals for markets and policy."
  canonical={new URL('/economy/', Astro.site).toString()}
>
  <Masthead activeNav="economy" />
  <main>
    <PolicyArchive
      items={items}
      section="economy"
      kicker="Economy"
      title="Macro prints, rates and RBI releases."
      dek="RBI releases and official data, arranged by source and subject so the signal is visible before the press-release wording takes over."
      empty="No economy notes yet."
    />
  </main>
  <SiteFooter />
</Base>
