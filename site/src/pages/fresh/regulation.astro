---
import Base from '../../layouts/Base.astro';
import Masthead from '../../components/Masthead.astro';
import PolicyArchive from '../../components/PolicyArchive.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { listRegulation } from '../../lib/queries.mjs';

const items = listRegulation({ limit: 150 });
---
<Base
  title="Regulation — SEBI, NSE, BSE & RBI, decoded"
  description="Editorial notes on the orders, circulars and rule changes from SEBI, the exchanges and the RBI that actually matter — enforcement, surveillance, derivatives, corporate actions and banking regulation."
  canonical={new URL('/regulation/', Astro.site).toString()}
>
  <Masthead activeNav="regulation" />
  <main>
    <PolicyArchive
      items={items}
      section="regulation"
      kicker="Regulation"
      title="SEBI, exchange and RBI action."
      dek="Orders, circulars and rule changes, reduced to the market consequence: who is affected, what changed, when it starts, and why it matters."
      empty="No regulation notes yet."
    />
  </main>
  <SiteFooter />
</Base>
