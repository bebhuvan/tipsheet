---
import Base from '../layouts/Base.astro';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getMarketSignals } from '../lib/queries.mjs';

const { groups, fetched_at } = getMarketSignals();
const DASHBOARD_URL = 'https://www.tijorifinance.com/dashboard/';

function dateOf(ms) {
  if (!ms) return '';
  const d = new Date(Number(ms));
  if (Number.isNaN(d.valueOf())) return '';
  const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
  return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`;
}

function signalLine(slug, card) {
  if (slug === 'rating-upgrades') return card.metric ? `${card.metric} → ${card.value}` : card.value;
  if (card.value) {
    if (slug === 'promoter-buying') return `Promoter bought ${card.value}`;
    if (slug === 'whales-buying') return `Big-investor stake ${card.value}`;
    return `${card.metric}: ${card.value}`;
  }
  return card.sector || '';
}

const intro = {
  'rating-upgrades': 'Fresh credit-rating actions from the agencies.',
  'promoter-buying': 'Promoters putting their own money in.',
  'whales-buying': 'Marquee investors building positions.',
};
---
<Base
  title="Alerts — market signals across Indian companies"
  description="Promoter and big-investor buying, corporate actions, capex and trending names — the market moves worth a glance, refreshed daily."
>
  <Masthead activeNav="alerts" />

  <main class="alerts-page">
    <header class="alerts-head">
      <div class="al-kicker">Alerts</div>
      <h1>Market signals</h1>
      <p class="al-dek">Market signals across India's listed companies — rating changes, promoter buying, and big-investor moves. The ownership and credit shifts worth a glance, refreshed daily.</p>
    </header>

    <a href={DASHBOARD_URL} target="_blank" rel="noopener" class="al-source">
      <span>These signals are pulled from Tijori's live market dashboard.</span>
      <strong>Open the full dashboard on Tijori ↗</strong>
    </a>

    {groups.length === 0 ? (
      <p class="al-empty">Signals refresh shortly — check back soon.</p>
    ) : groups.map(g => (
      <section class="sig-group">
        <div class="sig-group-head">
          <h2>{g.label}</h2>
          {intro[g.slug] && <p>{intro[g.slug]}</p>}
        </div>
        <ul class="sig-list">
          {g.cards.filter(c => signalLine(g.slug, c)).map(c => (
            <li class="sig">
              <a href={c.url} target="_blank" rel="noopener" class="sig-co">
                {c.company}{c.symbol && <span class="sig-sym">{c.symbol}</span>}
              </a>
              <span class="sig-detail">{signalLine(g.slug, c)}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <p class="al-foot">{fetched_at ? `As of ${dateOf(fetched_at)} · ` : ''}Market signals via Tijori. A research aid, not investment advice.</p>
  </main>

  <SiteFooter />
</Base>

<style>
  .alerts-page { max-width: 820px; margin: 0 auto; padding: 64px 24px 96px; }
  .alerts-head { margin-bottom: 28px; }
  .al-kicker {
    font-family: var(--mono); font-size: 11px; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--accent); font-weight: 500; margin-bottom: 14px;
  }
  .alerts-head h1 {
    font-family: var(--serif); font-weight: 400; font-size: 46px; line-height: 1.04;
    letter-spacing: -0.022em; margin: 0; color: var(--text);
  }
  .al-dek {
    font-family: var(--serif); font-size: 19px; line-height: 1.5; font-weight: 300;
    color: var(--text-muted); margin: 14px 0 0; max-width: 56ch;
  }

  /* Prominent source link at the top */
  .al-source {
    display: flex; align-items: baseline; justify-content: space-between; gap: 20px;
    margin: 0 0 44px; padding: 18px 22px;
    border-top: 1px solid var(--text); border-bottom: 1px solid var(--text);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    text-decoration: none; color: var(--text);
  }
  .al-source:hover { background: color-mix(in srgb, var(--accent) 9%, transparent); }
  .al-source span {
    font-family: var(--serif); font-style: italic; font-weight: 300; font-size: 17px;
    color: var(--text-soft);
  }
  .al-source strong {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 500; color: var(--accent); white-space: nowrap;
  }

  .sig-group { margin: 0 0 44px; }
  .sig-group-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 12px; flex-wrap: wrap; }
  .sig-group-head h2 {
    font-family: var(--serif); font-weight: 500; font-size: 22px; letter-spacing: -0.01em;
    margin: 0; color: var(--text);
  }
  .sig-group-head p {
    font-family: var(--serif); font-style: italic; font-weight: 300; font-size: 14px;
    color: var(--text-muted); margin: 0;
  }

  .sig-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--hairline-strong); }
  .sig {
    display: flex; align-items: baseline; justify-content: space-between; gap: 24px;
    padding: 14px 0; border-bottom: 1px solid var(--hairline);
  }
  .sig-co {
    font-family: var(--serif); font-size: 18px; color: var(--text); text-decoration: none;
    display: inline-flex; align-items: baseline; gap: 10px; min-width: 0;
  }
  .sig-co:hover { color: var(--accent); }
  .sig-sym {
    font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text-faint); font-weight: 500;
  }
  .sig-detail {
    font-family: var(--data); font-size: 14px; color: var(--text-soft); text-align: right;
    white-space: nowrap; font-feature-settings: "tnum" 1, "lnum" 1;
  }

  .al-empty { font-family: var(--serif); font-style: italic; color: var(--text-muted); }
  .al-foot {
    margin: 48px 0 0; padding-top: 18px; border-top: 1px solid var(--hairline);
    font-family: var(--serif); font-style: italic; font-weight: 300; font-size: 13px;
    color: var(--text-faint);
  }

  @media (max-width: 600px) {
    .alerts-head h1 { font-size: 36px; }
    .al-source { flex-direction: column; gap: 8px; }
    .sig { flex-direction: column; gap: 4px; }
    .sig-detail { text-align: left; }
  }
</style>
