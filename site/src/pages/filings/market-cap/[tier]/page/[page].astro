---
import Base from '../../../../../layouts/Base.astro';
import Masthead from '../../../../../components/Masthead.astro';
import SiteFooter from '../../../../../components/SiteFooter.astro';
import ArchiveList from '../../../../../components/ArchiveList.astro';
import { listFilings, MARKET_CAP_TIERS, marketCapTierBySlug } from '../../../../../lib/queries.mjs';

export async function getStaticPaths() {
  const PER_PAGE = 25;
  const paths = [];
  for (const t of MARKET_CAP_TIERS) {
    const all = listFilings({ marketCap: t, limit: 50000 });
    const totalPages = Math.max(1, Math.ceil(all.length / PER_PAGE));
    // Pages 2..N; page 1 lives at /filings/market-cap/<tier>/
    for (let p = 2; p <= totalPages; p++) {
      paths.push({
        params: { tier: t.slug, page: String(p) },
        props: { tierSlug: t.slug, page: p, totalPages, items: all.slice((p - 1) * PER_PAGE, p * PER_PAGE) },
      });
    }
  }
  return paths;
}

const { tierSlug, page, totalPages, items } = Astro.props;
const meta = marketCapTierBySlug(tierSlug);
const prevHref = page === 2 ? `/filings/market-cap/${tierSlug}/` : `/filings/market-cap/${tierSlug}/page/${page - 1}/`;
const nextHref = page < totalPages ? `/filings/market-cap/${tierSlug}/page/${page + 1}/` : null;
---
<Base
  title={`${meta.label} notes archive · page ${page}`}
  description={`${meta.label} notes, page ${page} of ${totalPages}.`}
>
  <Masthead activeNav="filings" capTier={tierSlug} />

  <main>
    <article class="archive-page">
      <header class="archive-header">
        <div class="kicker"><a href="/filings/">Archive</a> <span class="sep">/</span> <a href={`/filings/market-cap/${tierSlug}/`}>{meta.label}</a> <span class="sep">/</span> <span>Page {page}</span></div>
        <h1 class="page-title">{meta.label}</h1>
      </header>

      <div class="archive-filters compact">
        <span class="label">Filter by size:</span>
        <a href="/filings/">All caps</a>
        {MARKET_CAP_TIERS.map(t => (
          <a href={`/filings/market-cap/${t.slug}/`} class={t.slug === tierSlug ? 'active' : ''}>{t.label}</a>
        ))}
      </div>

      <ArchiveList items={items} />

      <nav class="pagination" aria-label="Pagination">
        <a href={prevHref} rel="prev">← Prev</a>
        <span class="current">Page {page} of {totalPages}</span>
        {nextHref && <a href={nextHref} rel="next">Next →</a>}
      </nav>
    </article>
  </main>

  <SiteFooter />
</Base>
