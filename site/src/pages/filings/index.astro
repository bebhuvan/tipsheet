---
import Base from '../../layouts/Base.astro';
import Masthead from '../../components/Masthead.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { listFilings, filingEyebrow, MARKET_CAP_TIERS } from '../../lib/queries.mjs';

// Page 1 — redirects pagination users to /filings/page/2/, /page/3/, etc.
const PER_PAGE = 25;
const all = listFilings({ limit: 50000 });
const totalPages = Math.max(1, Math.ceil(all.length / PER_PAGE));
const items = all.slice(0, PER_PAGE);

function timeOf(iso) { const m = String(iso || '').match(/(\d{2}):(\d{2})/); if (!m) return ''; let h = +m[1]; const ap = h < 12 ? 'AM' : 'PM'; h = h % 12 || 12; return `${h}:${m[2]} ${ap} IST`; }
function dateOf(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${String(d.getDate()).padStart(2,'0')} ${months[d.getMonth()]}`;
}

const categories = ['Earnings','Concalls','Order Wins','M&A','Credit','Regulatory'];
---
<Base
  title="Notes archive"
  description={`Every published note, newest first. ${all.length} notes covering Indian-equity exchange filings — earnings, order wins, concalls, M&A, credit actions and regulatory.`}
>
  <Masthead activeNav="filings" />

  <main>
    <article class="archive-page">
      <header class="archive-header">
        <div class="kicker"><span>Archive</span></div>
        <h1 class="page-title">Every note, newest first.</h1>
        <p class="page-dek">{all.length} published. Sortable view will come with the search feature in the next pass.</p>
      </header>

      <div class="archive-filters">
        <span class="label">Filter by category:</span>
        <a href="/filings/" class="active">All</a>
        {categories.map(c => (
          <a href={`/filings/category/${c.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'')}/`}>{c}</a>
        ))}
      </div>

      <div class="archive-filters compact">
        <span class="label">Filter by size:</span>
        <a href="/filings/" class="active">All caps</a>
        {MARKET_CAP_TIERS.map(t => (
          <a href={`/filings/market-cap/${t.slug}/`}>{t.label}</a>
        ))}
      </div>

      <div class="archive-list">
        {items.map(f => (
          <a href={f.canonical_url} class="archive-row">
            <span class="archive-row-meta">
              <span class="archive-date">{dateOf(f.created_on)} · {timeOf(f.created_on)}</span>
              <span class={`archive-score ${f.score >= 8 ? 'accent' : ''}`}>{f.score}</span>
              <span class="archive-ticker">{f.symbol}</span>
            </span>
            <div class="archive-body">
              <div class="kicker">{filingEyebrow(f)}</div>
              <h3>{f.headline}</h3>
            </div>
          </a>
        ))}
      </div>

      {totalPages > 1 && (
        <nav class="pagination" aria-label="Pagination">
          <span class="current">Page 1 of {totalPages}</span>
          {totalPages > 1 && <a href="/filings/page/2/" rel="next">Next →</a>}
        </nav>
      )}
    </article>
  </main>

  <SiteFooter />
</Base>
