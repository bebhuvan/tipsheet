---
import Base from '../../../layouts/Base.astro';
import Masthead from '../../../components/Masthead.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { listFilings, filingEyebrow, MARKET_CAP_TIERS } from '../../../lib/queries.mjs';

const CATEGORIES = [
  { slug: 'earnings',    name: 'Earnings',    dek: 'Quarterly and annual results, audited financials, board outcomes on results.' },
  { slug: 'concalls',    name: 'Concalls',    dek: 'Earnings-call transcripts and summaries.' },
  { slug: 'order-wins',  name: 'Order Wins',  dek: 'Major contract awards and order-book updates.' },
  { slug: 'm-a',         name: 'M&A',         dek: 'Acquisitions, CCI approvals, open offers, corporate actions.' },
  { slug: 'credit',      name: 'Credit',      dek: 'Rating changes, pledge creations, fundraises, monitoring reports.' },
  { slug: 'regulatory',  name: 'Regulatory',  dek: 'Auditor actions, SEBI matters, compliance disclosures.' },
];

export async function getStaticPaths() {
  return [
    { params: { name: 'earnings'    } },
    { params: { name: 'concalls'    } },
    { params: { name: 'order-wins'  } },
    { params: { name: 'm-a'         } },
    { params: { name: 'credit'      } },
    { params: { name: 'regulatory'  } },
  ];
}

const { name } = Astro.params;
const meta = CATEGORIES.find(c => c.slug === name);
if (!meta) return Astro.redirect('/404');

const items = listFilings({ category: meta.name, limit: 100 });

function timeOf(iso) { const m = String(iso || '').match(/(\d{2}):(\d{2})/); if (!m) return ''; let h = +m[1]; const ap = h < 12 ? 'AM' : 'PM'; h = h % 12 || 12; return `${h}:${m[2]} ${ap} IST`; }
function dateOf(iso) {
  const d = new Date(String(iso).replace(' ', 'T'));
  if (Number.isNaN(d.valueOf())) return iso;
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${String(d.getDate()).padStart(2,'0')} ${months[d.getMonth()]}`;
}
---
<Base
  title={`${meta.name} — notes archive`}
  description={meta.dek}
>
  <Masthead activeNav="filings" />

  <main>
    <article class="archive-page">
      <header class="archive-header">
        <div class="kicker"><a href="/filings/">Archive</a> <span class="sep">/</span> <span>{meta.name}</span></div>
        <h1 class="page-title">{meta.name}</h1>
        <p class="page-dek">{meta.dek}</p>
      </header>

      <div class="archive-filters">
        <span class="label">Filter by category:</span>
        <a href="/filings/">All</a>
        {CATEGORIES.map(c => (
          <a href={`/filings/category/${c.slug}/`} class={c.slug === name ? 'active' : ''}>{c.name}</a>
        ))}
      </div>

      <div class="archive-filters compact">
        <span class="label">Filter by size:</span>
        <a href="/filings/">All caps</a>
        {MARKET_CAP_TIERS.map(t => (
          <a href={`/filings/market-cap/${t.slug}/`}>{t.label}</a>
        ))}
      </div>

      <div class="archive-list">
        {items.length === 0 && <p style="font-style: italic; color: var(--text-muted); padding: 24px 0;">No notes in this category yet.</p>}
        {items.map(f => (
          <a href={f.canonical_url} class="archive-row">
            <span class="archive-date">{dateOf(f.created_on)} · {timeOf(f.created_on)}</span>
            <span class={`archive-score ${f.score >= 8 ? 'accent' : ''}`}>{f.score}</span>
            <div class="archive-body">
              <div class="kicker">{filingEyebrow(f, { category: false })}</div>
              <h3>{f.headline}</h3>
            </div>
            <span class="archive-ticker">{f.symbol}</span>
          </a>
        ))}
      </div>
    </article>
  </main>

  <SiteFooter />
</Base>
