# Cloudflare Pages custom headers
# https://developers.cloudflare.com/pages/configuration/headers/
#
# NOTE: requests route through worker-entry.js first so HTML page caching,
# security headers, API routes, and redirects share one code path. These static
# asset rules remain as a fallback and document the intended cache policy, but
# worker-entry.js is the runtime source of truth after deployment.

# Astro content-hashed bundles (filename changes on every content change) —
# safe to cache forever. No other rule matches /_assets/, so this stays clean.
/_assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/icon-*.png
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

/search-index.json
  Cache-Control: public, max-age=3600

/feed.xml
  Cache-Control: public, max-age=1800

/feed.json
  Cache-Control: public, max-age=1800

/sitemap.xml
  Cache-Control: public, max-age=3600

/sitemap-news.xml
  Cache-Control: public, max-age=1800

# Plain-text discovery files. Pin charset so non-ASCII (em-dashes, currency
# glyphs) can't render as mojibake under X-Content-Type-Options: nosniff.
/llms.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
/robots.txt
  Content-Type: text/plain; charset=utf-8
