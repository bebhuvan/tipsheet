# Primary LLM: Gemini 3.1 Flash Lite via native Google AI Studio (OpenAI-compatible endpoint).
# Won 22-May-2026 bakeoff vs DeepSeek/Qwen/GLM. Native pricing: $0.10/M in, $0.40/M out.
# Get a key at https://ai.studio.google.com/apikey
GOOGLE_API_KEY=AIza...
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=${GOOGLE_API_KEY}
LLM_MODEL=gemini-3.1-flash-lite

# Backup providers (not auto-used; manually swap LLM_* above):
OPENROUTER_API_KEY=sk-or-v1-...
DEEPSEEK_API_KEY=sk-...

# Tijori B2B feed URL — knowledge of this URL = access. Never commit. Never log.
TIJORI_FEED_URL=https://ce.b2b.tijorifinance.com/latest?from_timestamp=2025-01-01%2000:00:00

# Tijori Kite Screener fundamentals — also a B2B endpoint, treat as a secret.
KITE_SCREENER_URL=https://b2b.tijorifinance.com/b2b/v1/in/api/kite-screener/fundamental/

# Tijori Concall Monitor — Bearer token, header: `Authorization: Bearer {key}`.
# Spec: https://www.tijoristack.ai/api/v1/docs/concalls/ (OpenAPI: /static/spec/v1/concalls.json)
TIJORI_CONCALLS_API_KEY=
TIJORI_CONCALLS_BASE_URL=https://www.tijoristack.ai/api/v1

# India Data Hub — macroeconomic + sector data series (banking, inflation, IIP, GDP, FX, money supply).
# Docs at https://feeds.indiadatahub.com/documentation?urls.primaryName=Economic%20Monitor
INDIA_DATAHUB_API_KEY=
INDIA_DATAHUB_BASE_URL=https://feeds.indiadatahub.com

# Pipeline tuning
SCORE_MIN=5
PARALLEL=4
POLL_INTERVAL_SEC=120
ENRICH_BATCH_SIZE=50

# Telegram distribution. Default mode is digest, which consolidates articles
# published since the previous run into one Telegram message.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DELIVERY_MODE=digest                  # digest | individual
TELEGRAM_SCOPE=all                             # all | briefings | articles
NOTIFY_SCORE_MIN=5
SITE_URL=https://tipsheet.markets

# Cloudflare Worker watchdog. Set these as Cloudflare secrets/vars, not public
# client values. The token needs permission to dispatch GitHub Actions workflows.
GITHUB_REPOSITORY=owner/repo
GITHUB_ACTIONS_TOKEN=github_pat_...
WATCHDOG_WORKFLOW=pipeline.yml
WATCHDOG_BRANCH=main
WATCHDOG_MAX_STALE_MIN=45

# Optional separate LLM for Telegram digests. Falls back to LLM_* above.
TELEGRAM_LLM_BASE_URL=
TELEGRAM_LLM_API_KEY=
TELEGRAM_LLM_MODEL=

# Optional overrides
LLM_MAX_TOKENS=2500
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_MS=30000
DB_PATH=                                        # default: ../data/filings.db
