# CI environment stub.
# Actual values are injected via GitHub Actions secrets (env: block in the workflow).
# This file exists so `node --env-file=../.env.ci` doesn't error on a missing file.
# Pipeline tuning defaults — same as .env.example.
SCORE_MIN=5
PARALLEL=4
LLM_MAX_TOKENS=2500
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_MS=30000
